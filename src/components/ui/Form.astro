---
/**
 * @deprecated このコンポーネントはどのページからも使用されていません。
 * Contact.astro 経由でインポートされていますが、Contact.astro 自体も本番ページでは未使用です。
 *
 * 実際の問い合わせ経路:
 *   - 外部リンク: RENKEI_VISIT_CONSULT_FORM_URL（Googleフォーム）
 *   - 電話: src/data/clinic-contact.ts の CLINIC_CONTACT.telDisplay
 *
 * このコンポーネントを実際に使用する場合は action 属性を必ず設定し、
 * 3省2ガイドライン準拠の送信先（医療対応SaaS等）を指定してください。
 */
import type { Form as Props } from '~/types';
import Button from '~/components/ui/Button.astro';

const { inputs, textarea, disclaimer, button = 'Contact us', description = '' } = Astro.props;
---

<form>
  {
    inputs &&
      inputs.map(
        ({ type = 'text', name, label = '', autocomplete = 'on', placeholder = '' }) =>
          name && (
            <div class="mb-6">
              {label && (
                <label for={name} class="block text-sm font-medium">
                  {label}
                </label>
              )}
              <input
                type={type}
                name={name}
                id={name}
                autocomplete={autocomplete}
                placeholder={placeholder}
                class="py-3 px-4 block w-full text-md rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900"
              />
            </div>
          )
      )
  }

  {
    textarea && (
      <div>
        <label for="textarea" class="block text-sm font-medium">
          {textarea.label}
        </label>
        <textarea
          id="textarea"
          name={textarea.name ? textarea.name : 'message'}
          rows={textarea.rows ? textarea.rows : 4}
          placeholder={textarea.placeholder}
          class="py-3 px-4 block w-full text-md rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900"
        />
      </div>
    )
  }

  {/* 個人情報保護方針への同意（必須）*/}
  <div class="mt-3 flex items-start">
    <div class="flex mt-0.5">
      <input
        id="privacy-consent"
        name="privacy-consent"
        type="checkbox"
        required
        class="cursor-pointer mt-1 w-4 h-4 rounded border border-gray-400 dark:border-gray-600 bg-white dark:bg-slate-900 accent-primary"
      />
    </div>
    <div class="ml-3">
      <label for="privacy-consent" class="cursor-pointer select-none text-sm text-gray-600 dark:text-gray-400">
        <a href="/privacy" target="_blank" rel="noopener" class="underline text-primary hover:opacity-80">個人情報保護方針</a>に同意のうえ送信します。<span class="text-red-500 ml-0.5" aria-label="必須">*</span>
      </label>
    </div>
  </div>

  {
    disclaimer && (
      <div class="mt-3 flex items-start">
        <div class="flex mt-0.5">
          <input
            id="disclaimer"
            name="disclaimer"
            type="checkbox"
            class="cursor-pointer mt-1 w-4 h-4 rounded border border-gray-400 dark:border-gray-600 bg-white dark:bg-slate-900 accent-primary"
          />
        </div>
        <div class="ml-3">
          <label for="disclaimer" class="cursor-pointer select-none text-sm text-gray-600 dark:text-gray-400">
            {disclaimer.label}
          </label>
        </div>
      </div>
    )
  }

  {
    button && (
      <div class="mt-10 grid">
        <Button variant="primary" type="submit">
          {button}
        </Button>
      </div>
    )
  }

  {
    description && (
      <div class="mt-3 text-center">
        <p class="text-sm text-gray-600 dark:text-gray-400">{description}</p>
      </div>
    )
  }
</form>
