---
import '@fontsource-variable/inter';
---

<!-- Noto Sans JP (日本語フォント) – preload でLCP改善 -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<!-- 医師写真ドメインへのpreconnect（LCP改善） -->
<link rel="preconnect" href="https://kamome-clinic.net" />
<link rel="dns-prefetch" href="https://kamome-clinic.net" />
<link
  rel="preload"
  as="style"
  href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700;900&display=swap"
/>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap" rel="stylesheet" />

<style is:inline>
  :root {
    --aw-font-sans: 'Noto Sans JP', 'Inter Variable', ui-sans-serif, system-ui, sans-serif;
    --aw-font-serif: 'Noto Sans JP', ui-serif, serif;
    --aw-font-heading: 'Noto Sans JP', 'Inter Variable', ui-sans-serif, system-ui, sans-serif;

    /* ───── かもめクリニック ロゴブルー ───── */
    --aw-color-primary: rgb(24 80 163);
    --aw-color-primary-tint: rgb(24 80 163 / 6%);
    --aw-color-secondary: rgb(10 40 100);
    --aw-color-accent: rgb(231 111 81);

    /* ───── ブランドカラー（固定値） ───── */
    --aw-color-line: #06c755;
    --aw-color-line-hover: #05a847;
    --aw-color-bg-header-dark: rgb(3 6 33 / 90%);

    /* ───── テキスト ───── */
    --aw-color-text-heading: rgb(10 25 55);
    --aw-color-text-default: rgb(25 45 75);
    --aw-color-text-muted: rgb(45 65 105);

    /* ───── 背景（ウォームベージュ） ───── */
    --aw-color-bg-page: rgb(253 248 241);
    --aw-color-bg-page-dark: rgb(15 23 42);

    /* ───── ライトモード専用宣言（ブラウザ強制ダークモード防止） ───── */
    color-scheme: light;

    ::selection {
      background-color: rgb(24 80 163 / 15%);
      color: rgb(10 25 55);
    }
  }

  /* ───── ダークモード時の CSS変数上書き（light:only でも .dark クラスが付いた場合の保険） ───── */
  /* 背景と文字色を一貫してダーク系に統一し、「ライト背景 + 淡い文字」の事故を防ぐ             */
  .dark {
    --aw-color-bg-page: rgb(15 23 42);
    --aw-color-text-heading: rgb(226 232 240);   /* slate-200 / コントラスト 11.2:1 on dark bg */
    --aw-color-text-default: rgb(203 213 225);   /* slate-300 / コントラスト  8.7:1 on dark bg */
    --aw-color-text-muted:   rgb(148 163 184);   /* slate-400 / コントラスト  5.2:1 on dark bg */
  }
  .dark body {
    background-color: rgb(15 23 42);
    color: rgb(203 213 225);
  }

/* ───── ベースフォントサイズ ───── */
  html {
    font-size: 20px;
  }
  @media (max-width: 1024px) {
    html {
      font-size: 19px;
    }
  }
  @media (max-width: 768px) {
    html {
      font-size: 17px;
    }
  }
  @media (max-width: 480px) {
    html {
      font-size: 17px;
    }
  }

  /* ───── 日本語フォント最適化 ───── */
  body {
    font-family: var(--aw-font-sans);
    font-feature-settings: 'palt' 1;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    line-height: 1.75;
    color: var(--aw-color-text-default);
    background-color: var(--aw-color-bg-page);
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    font-weight: 700;
    line-height: 1.35;
    letter-spacing: -0.01em;
    color: var(--aw-color-text-heading);
  }

  p {
    line-height: 1.85;
    letter-spacing: 0.02em;
    font-size: 1rem;
  }

  /* ───── 浮動CTAボタン ───── */
  @keyframes floatingCtaIn {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .floating-cta {
    position: fixed;
    bottom: 1.5rem;
    right: 1rem;
    z-index: 9998;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.5rem;
    /* ページ読み込み直後から即座表示 */
    animation: floatingCtaIn 0.35s ease forwards;
  }

  /* View Transitions 対応：再アニメーション防止 */
  .floating-cta.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .floating-cta a {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1.4rem;
    border-radius: 9999px;
    font-weight: 700;
    font-size: 1rem;
    box-shadow: 0 4px 20px rgb(0 0 0 / 22%);
    transition:
      transform 0.2s,
      box-shadow 0.2s;
    text-decoration: none !important;
    white-space: nowrap;
  }

  .floating-cta a:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgb(0 0 0 / 30%);
  }

  /* 固定CTAと同じ見た目を本文セクションでも使う（親が .floating-cta でなくても有効） */
  .floating-cta-inline {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1.4rem;
    border-radius: 9999px;
    font-weight: 700;
    font-size: 1rem;
    box-shadow: 0 4px 20px rgb(0 0 0 / 22%);
    transition:
      transform 0.2s,
      box-shadow 0.2s;
    text-decoration: none !important;
    white-space: nowrap;
  }
  .floating-cta-inline:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgb(0 0 0 / 30%);
  }
  .floating-cta-inline-tel {
    background-color: var(--aw-color-primary);
    color: white !important;
  }
  .floating-cta-inline-form {
    background-color: white;
    color: var(--aw-color-primary) !important;
    border: 2px solid var(--aw-color-primary);
    padding: 0.6rem 1rem !important;
    font-size: 0.85rem !important;
  }

  .floating-cta-tel {
    background-color: var(--aw-color-primary);
    color: white !important;
  }

  .floating-cta-line {
    background-color: var(--aw-color-line);
    color: white !important;
    padding: 0.7rem 1.2rem !important;
    font-size: 0.95rem !important;
  }

  .floating-cta-mail,
  .floating-cta-form {
    background-color: white;
    color: var(--aw-color-primary) !important;
    border: 2px solid var(--aw-color-primary);
    padding: 0.6rem 1rem !important;
    font-size: 0.85rem !important;
  }

  @media (max-width: 640px) {
    /* モバイル：右下の縦積みをやめ、画面下部の固定バーに切り替え */
    .floating-cta {
      bottom: 0;
      right: 0;
      left: 0;
      flex-direction: row;
      align-items: stretch;
      gap: 0;
      border-radius: 0;
      border-top: 2px solid rgba(0, 0, 0, 0.08);
      box-shadow: 0 -2px 16px rgb(0 0 0 / 14%);
      background: white;
      padding-bottom: env(safe-area-inset-bottom, 0);
    }
    .floating-cta a {
      flex: 1;
      justify-content: center;
      flex-direction: column;
      border-radius: 0;
      padding: 0.5rem 0.25rem !important;
      font-size: 0.875rem !important;
      gap: 0.25rem !important;
      box-shadow: none;
      min-height: 64px;
    }
    .floating-cta a svg,
    .floating-cta a [data-icon] {
      width: 1.375rem;
      height: 1.375rem;
    }
    .floating-cta a:hover {
      transform: none;
      box-shadow: none;
    }
    /* フォームボタン：電話との区切り（下部固定バーは白背景） */
    .floating-cta-form {
      border-left: 1px solid rgba(0, 0, 0, 0.1) !important;
    }
    /* ボトムバー分のコンテンツ下余白（浮動CTAがあるページのみ） */
    body:has(#floating-cta) {
      padding-bottom: calc(64px + env(safe-area-inset-bottom, 0px));
    }
  }

  /* ───── 50代向け可読性：Tailwind gray系コントラスト強化 ───── */
  .text-gray-400 { color: rgb(100, 110, 128); }  /* 2.1:1 → 3.8:1 */
  .text-gray-500 { color: rgb(85, 94, 110); }    /* 3.7:1 → 5.0:1 */
  .text-gray-600 { color: rgb(60, 70, 88); }     /* 5.2:1 → 6.5:1 */
</style>
