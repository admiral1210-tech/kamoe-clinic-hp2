---
import { Icon } from 'astro-icon/components';
import { SITE } from 'astrowind:config';
import { getHomePermalink } from '~/utils/permalinks';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

interface Links {
  title?: string;
  links: Array<Link>;
}

export interface Props {
  links: Array<Links>;
  secondaryLinks: Array<Link>;
  socialLinks: Array<Link>;
  footNote?: string;
  theme?: string;
}

const { socialLinks = [], secondaryLinks = [], links = [], theme = 'light' } = Astro.props;
---

<footer class:list={[{ dark: theme === 'dark' }, 'relative border-t border-gray-200 dark:border-slate-800 not-prose']}>
  <div class="dark:bg-dark absolute inset-0 pointer-events-none" aria-hidden="true"></div>
  <div
    class="relative max-w-7xl mx-auto px-4 sm:px-6 dark:text-slate-300 intersect-once intersect-quarter intersect-no-queue motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
  >
    <!-- 上段：クリニック情報 + リンクグリッド -->
    <div class="py-8 flex flex-col lg:flex-row gap-8 border-b border-gray-100 dark:border-slate-700">
      <!-- クリニック情報ブロック（住所・TEL・診療時間） -->
      <div class="shrink-0 space-y-3 lg:w-56">
        <a
          class="font-bold text-base text-gray-900 dark:text-white hover:text-primary transition-colors block"
          href={getHomePermalink()}
        >
          {SITE?.name}
        </a>

        <address class="not-italic space-y-2 text-sm text-muted dark:text-gray-400">
          <p class="flex items-start gap-2">
            <Icon name="tabler:map-pin" class="w-4 h-4 shrink-0 mt-0.5 text-primary" />
            <span>〒552-0004 大阪市港区夕凪2丁目16-9<br />icrossAMポートビル 4F-B</span>
          </p>
          <p class="flex items-center gap-2">
            <Icon name="tabler:phone" class="w-4 h-4 shrink-0 text-primary" />
            <a href="tel:0643017871" class="text-blue-600 dark:text-blue-400 underline hover:no-underline">
              06-4301-7871
            </a>
          </p>
          <p class="flex items-center gap-2">
            <Icon name="tabler:clock" class="w-4 h-4 shrink-0 text-primary" />
            <span>平日・祝日 9:00〜17:00<br />緊急往診 24時間365日</span>
          </p>
        </address>

        <!-- ソーシャルリンク -->
        <div class="flex items-center gap-1 pt-1">
          {
            socialLinks.map(({ ariaLabel, href, icon }) => {
              const isInstagram = ariaLabel === 'Instagram';
              const isLine = ariaLabel === 'LINE';
              const socialClass = isInstagram
                ? 'text-[#E4405F] bg-[#E4405F]/10 hover:bg-[#E4405F]/20 dark:bg-[#E4405F]/15 dark:hover:bg-[#E4405F]/30'
                : isLine
                  ? 'text-[#06C755] bg-[#06C755]/10 hover:bg-[#06C755]/20 dark:bg-[#06C755]/15 dark:hover:bg-[#06C755]/30'
                  : 'text-muted dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700';

              return (
                <a
                  class:list={[
                    'rounded-xl p-3 inline-flex items-center transition-colors',
                    socialClass,
                  ]}
                  aria-label={ariaLabel}
                  href={href}
                >
                  {icon && <Icon name={icon} class="w-6 h-6" />}
                </a>
              );
            })
          }
        </div>
      </div>

      <!-- リンクグリッド（各セクションタイトルあり） -->
      <nav class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-x-4 gap-y-6 flex-1">
        {
          links.map(({ title, links: sectionLinks }) => (
            <div>
              <p class="font-bold text-xs text-gray-900 dark:text-white mb-2 tracking-wide">{title}</p>
              <ul class="space-y-1.5">
                {sectionLinks.map(({ text, href, ariaLabel }) => (
                  <li>
                    <a
                      class="text-sm text-muted hover:text-gray-700 hover:underline dark:text-gray-400 dark:hover:text-gray-200 transition duration-150 ease-in-out leading-snug block"
                      href={href}
                      aria-label={ariaLabel}
                    >
                      <Fragment set:html={text} />
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </nav>
    </div>

    <!-- 下段：セカンダリリンク + コピーライト -->
    <div class="py-4 flex flex-wrap items-center justify-between gap-3 text-sm text-muted dark:text-muted">
      <div class="flex flex-wrap gap-4">
        {
          secondaryLinks.map(({ text, href }) => (
            <a
              class="hover:text-gray-700 dark:text-gray-400 hover:underline transition duration-150 ease-in-out"
              href={href}
              set:html={text}
            />
          ))
        }
      </div>
      <p class="text-xs text-muted dark:text-muted">
        © {new Date().getFullYear()} かもめクリニック
      </p>
    </div>
  </div>
</footer>
