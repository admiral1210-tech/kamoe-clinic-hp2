  ],
  numberOfEmployees: buildNumberOfEmployees(),
  ...(buildAggregateRating() ? { aggregateRating: buildAggregateRating() } : {}),
  sameAs: [
    'https://line.me/R/ti/p/%40512ysmzx',
    'https://www.instagram.com/kamomeclinic/',
    'https://www.kamome-clinic.net',
    'https://kamome-clinic5.net/',
    'https://kamome-clinic7.net/',
  ],
  hasMap: 'https://maps.google.com/maps?q=%E5%A4%A7%E9%98%AA%E5%B8%82%E6%B8%AF%E5%8C%BA%E5%A4%95%E5%87%AA2%E4%B8%81%E7%9B%AE16-9',
  privacyPolicy: 'https://kamome-clinic.net/privacy',
  priceRange: '保険適用（自己負担1〜3割）',
  areaServed: ['大阪市港区','大阪市西淀川区','大阪市住之江区','大阪市西区','大阪市大正区','大阪市浪速区','大阪市此花区','大阪市淀川区'],
};

// ===== JSON-LD: 各支院 LocalBusiness =====
const jsonLdBranches = [
  { name:'かもめクリニック第2', street:'夕凪2丁目17-14',             tel:'+81-6-6556-9571', bid:'branch2' as const },
  { name:'かもめクリニック第3', street:'東住吉区駒川3丁目29-14',    tel:'+81-6-6115-6045', bid:'branch3' as const },
  { name:'かもめクリニック第4', street:'西淀川区柏里1丁目16-15',    tel:'+81-6-7506-9565', bid:'branch4' as const },
  { name:'かもめクリニック第5', street:'住之江区北加賀屋2-12-6', tel:'+81-6-6115-7018', bid:'branch5' as const },
  { name:'かもめクリニック第8', street:'住吉区千躰2-2-39 ホリビル3階', tel:'+81-6-6629-8852', bid:'branch8' as const },
].map(b => ({
  '@context': 'https://schema.org',
  '@id': `https://kamome-clinic.net/#${b.bid}`,
  '@type': 'MedicalClinic',
  name: b.name,
  parentOrganization: { '@type': 'MedicalClinic', '@id': 'https://kamome-clinic.net/#clinic', name: 'かもめクリニック' },
  address: { '@type': 'PostalAddress', streetAddress: b.street, addressLocality: '大阪市', addressRegion: '大阪府', addressCountry: 'JP' },
  telephone: b.tel,
  ...(getBranchFoundingDate(b.bid) ? { foundingDate: getBranchFoundingDate(b.bid) } : {}),
}));

// ===== JSON-LD: 医師情報（Physician） =====
const jsonLdPhysicians = [
  { name:'木下 啓太', jobTitle:'院長', spec:['https://schema.org/InternalMedicine'], cert:'日本内科学会認定医・腎臓学会専門医・透析医学会専門医' },
  { name:'石本 英之', jobTitle:'精神科専門医', spec:['https://schema.org/Psychiatry'], cert:'精神保健指定医・医学博士・日本神経精神学会専門医' },
  { name:'菅近 優',   jobTitle:'精神科専門医・指導医', spec:['https://schema.org/Psychiatry'], cert:'精神保健指定医・医学博士・指導医' },
  { name:'西田 宜代', jobTitle:'精神科専門医', spec:['https://schema.org/Psychiatry'], cert:'精神保健指定医' },
  { name:'河内 要',   jobTitle:'第4院院長', spec:['https://schema.org/Pediatrics'], cert:'小児科専門医' },
].map(d => ({
  '@context': 'https://schema.org',
  '@type': 'Physician',
  name: d.name,
  jobTitle: d.jobTitle,
  medicalSpecialty: d.spec,
  description: d.cert,
  worksFor: { '@type': 'MedicalClinic', '@id': 'https://kamome-clinic.net/#clinic', name: 'かもめクリニック' },
  url: 'https://kamome-clinic.net/#doctors',
}));

// ===== JSON-LD: FAQ（AEO最適化・直接回答形式） =====
const jsonLdFAQ = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: '訪問診療は誰でも利用できますか？', acceptedAnswer: { '@type': 'Answer', text: '通院が困難な方であれば、どなたでもご利用いただけます。高齢者、障がいのある方、精神疾患、医療的ケアが必要なお子さまが対象です。紹介状は不要ですので、まずはお電話（06-4301-7871）またはLINEでご相談ください。' } },
    { '@type': 'Question', name: '訪問診療の費用はいくらですか？', acceptedAnswer: { '@type': 'Answer', text: '健康保険・介護保険が適用されます。後期高齢者（75歳以上・1割負担）の方は、月2回の定期訪問で月5,000〜8,000円が目安です（薬代・処置費用は別途）。生活保護の方は自己負担0円。2割・3割負担の方は2〜3倍が目安です。詳しくは費用・保険ページをご覧ください。' } },
    { '@type': 'Question', name: '申し込みから訪問開始まで何日かかりますか？', acceptedAnswer: { '@type': 'Answer', text: 'ご相談のあと、訪問開始は最短当日を目指しています。担当エリアと患者さまの状況を確認のうえ、迅速に対応します。まずはお電話（06-4301-7871）またはLINEでご連絡ください。' } },
    { '@type': 'Question', name: '精神科の訪問診療も受けられますか？', acceptedAnswer: { '@type': 'Answer', text: 'はい。精神科専門医が3名常勤し、大阪市内の訪問診療クリニックとして唯一の体制です。うつ病・統合失調症・双極性障害・認知症・アルコール依存症・PTSDなどに対応しています。' } },
    { '@type': 'Question', name: '訪問診療と往診の違いは何ですか？', acceptedAnswer: { '@type': 'Answer', text: '訪問診療は、月2回など定期的に医師が訪問する計画的な医療です。往診は、患者さまの急変時に臨時で医師が訪問するものです。かもめクリニックはどちらにも対応し、定期訪問診療に加えて24時間365日の緊急往診も行っています。' } },
    { '@type': 'Question', name: '大阪市のどのエリアに対応していますか？', acceptedAnswer: { '@type': 'Answer', text: '大阪市内全域を5院体制で対応しています。港区・西淀川区・住之江区・住吉区・東住吉区など主要区をカバーしています。エリア外のご相談は、地域医療連携部（06-4301-7883）へお気軽にどうぞ。' } },
    { '@type': 'Question', name: '夜間・休日に急に具合が悪くなったときは？', acceptedAnswer: { '@type': 'Answer', text: '機能強化型在宅療養支援診療所（在支診1）として、24時間365日の緊急往診に対応しています。夜間・休日でも担当医へ直接連絡できます。急変時は翌日を待たずにお電話ください。緊急時の連絡先・対応手順は訪問開始時にご説明します。' } },
    { '@type': 'Question', name: '機能強化型在宅療養支援診療所（在支診1）とはどういう施設ですか？', acceptedAnswer: { '@type': 'Answer', text: '厚生労働省が定める在宅医療の最上位区分で、正式名称は機能強化型在宅療養支援診療所（在支診1）です。常勤医師3名以上・24時間365日対応・年間の看取り実績など、厳しい基準を満たした診療所のみが認定されます。かもめクリニックは2017年開院以来、在支診1として大阪市内の在宅医療を支えています。' } },
    { '@type': 'Question', name: 'グループホームや老人ホームでも利用できますか？', acceptedAnswer: { '@type': 'Answer', text: 'はい。有料老人ホーム・グループホーム・特別養護老人ホーム・サービス付き高齢者向け住宅など、入居施設にも訪問しています。グループ全体で約50施設への訪問診療を行い、施設スタッフ・ケアマネジャーとの連携も積極的に行っています。' } },
    { '@type': 'Question', name: '医療ケアが必要な子どもの訪問診療はできますか？', acceptedAnswer: { '@type': 'Answer', text: '対応しています。小児科専門医・小児循環器専門医が在籍し、人工呼吸器・経管栄養・気管切開・吸引・酸素療法など、医療的ケアが必要なお子さまの在宅診療を行っています。NICU退院後の在宅移行支援実績も約10件。退院前からのご相談も可能です。' } },
    { '@type': 'Question', name: '在宅での看取りはできますか？', acceptedAnswer: { '@type': 'Answer', text: 'はい。グループ全体で年間約100件の在宅看取りを行っています。ご本人・ご家族の意思を尊重し、住み慣れた場所での最期を支えます。在支診1として24時間365日対応できる体制を整えており、終末期のご相談はいつでもお気軽にご連絡ください。' } },
    { '@type': 'Question', name: '精神科の訪問診療を頼むことは恥ずかしくないですか？', acceptedAnswer: { '@type': 'Answer', text: '恥ずかしいことではありません。精神疾患は糖尿病と同じく病気です。守秘義務のもと丁寧に対応します。訪問診療で回復に向かうケースも多くあります。まずはLINEやお電話でご相談ください。' } },
  ],
};

// ===== JSON-LD: HowTo（利用の流れ） =====
const jsonLdHowTo = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: '訪問診療のご利用開始までの流れ（かもめクリニック）',
  description: '訪問診療を始めるまでの4ステップです。最短当日の開始を目指しています。',
  totalTime: 'P7D',
  step: [
    { '@type': 'HowToStep', position: 1, name: 'まずはご相談（電話・LINE・メール）', text: 'TEL 06-4301-7871 またはLINE（@512ysmzx）で、患者さまの状態とお住まいをお知らせください。' },
    { '@type': 'HowToStep', position: 2, name: '担当エリア・状況の確認', text: 'ご住所と病状を確認し、最寄り拠点の担当医を決めます。当日から翌営業日以内にご連絡します。' },
    { '@type': 'HowToStep', position: 3, name: '初回訪問・診療計画の説明', text: '担当医が初回訪問し、診療計画・訪問スケジュール・緊急時の連絡方法をわかりやすくご説明します。' },
    { '@type': 'HowToStep', position: 4, name: '定期訪問診療スタート', text: '月2回の定期訪問診療が始まります。急変時は24時間365日、担当医へ直接ご連絡いただけます。' },
  ],
};

// ===== JSON-LD: WebSite（サイト検索ボックス対応） =====
const jsonLdWebSite = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': 'https://kamome-clinic.net/#website',
  name: 'かもめクリニック',
  url: 'https://kamome-clinic.net',
  publisher: { '@type': 'MedicalClinic', '@id': 'https://kamome-clinic.net/#clinic' },
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://kamome-clinic.net/#faq',
    'query-input': 'required name=search_term_string',
  },
};

// ===== JSON-LD: BreadcrumbList =====
const jsonLdBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://kamome-clinic.net/' },
  ],
};

// ===== JSON-LD: Review（患者さまの声） =====
// TODO: 実際の体験談が集まり次第、以下のプレースホルダーを差し替えてください。
const jsonLdReviews = [
  {
    '@context': 'https://schema.org',
    '@type': 'Review',
    author: { '@type': 'Person', name: 'K.T.様（港区・70代男性のご家族）' },
    reviewRating: { '@type': 'Rating', ratingValue: '5', bestRating: '5' },
    reviewBody: 'TODO: 実際の体験談テキストに差し替えてください。',
    itemReviewed: { '@type': 'MedicalClinic', '@id': 'https://kamome-clinic.net/#clinic', name: 'かもめクリニック' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Review',
    author: { '@type': 'Person', name: 'M.S.様（住之江区・80代女性ご本人）' },
    reviewRating: { '@type': 'Rating', ratingValue: '5', bestRating: '5' },
    reviewBody: 'TODO: 実際の体験談テキストに差し替えてください。',
    itemReviewed: { '@type': 'MedicalClinic', '@id': 'https://kamome-clinic.net/#clinic', name: 'かもめクリニック' },
  },
];

// ===== JSON-LD: Speakable（音声検索対応） =====
const jsonLdSpeakable = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': 'https://kamome-clinic.net/',
  name: 'かもめクリニック 訪問診療',
  datePublished: '2017-04-01',
  dateModified: '2026-03-20',
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['#about-houmon', '#faq', '#features', '.note-content'],
  },
  url: 'https://kamome-clinic.net',
};
---

<Layout metadata={metadata}>

  <Fragment slot="head">
    <!-- ヒーロー画像（LCP要素）のpreload -->
    <link rel="preload" as="image" href="/images/hero-group.jpg" fetchpriority="high" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdClinic)} />
    {jsonLdBranches.map(b => <script type="application/ld+json" set:html={JSON.stringify(b)} />)}
    {jsonLdPhysicians.map(p => <script type="application/ld+json" set:html={JSON.stringify(p)} />)}
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdFAQ)} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdHowTo)} />
    {jsonLdReviews.map(r => <script type="application/ld+json" set:html={JSON.stringify(r)} />)}
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdSpeakable)} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebSite)} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdBreadcrumb)} />
  </Fragment>

  <!-- ============================================================ Hero ================================================================ -->
  <Hero
    tagline="大阪市の訪問診療専門｜24時間365日・大阪市内5院体制"
    actions={[
      { variant: 'primary', text: 'お電話でのご相談', href: 'tel:0643017871', icon: 'tabler:phone' },
      { variant: 'line', text: 'LINEで無料相談', href: 'https://line.me/R/ti/p/%40512ysmzx', icon: 'tabler:brand-line' },
    ]}
  >
    <Fragment slot="image">
      <div class="w-full mt-8">
        <img
          src="/images/hero-group.jpg"
          alt="かもめクリニックのスタッフチーム"
          class="w-full rounded-2xl object-cover shadow-xl"
          width="1400"
          height="500"
          style="max-height: 480px; object-position: center top;"
        />
      </div>
    </Fragment>
    <Fragment slot="title">
      <span class="sm:hidden">
        ご自宅・施設への<br />
        <span class="text-accent dark:text-white highlight">訪問診療</span>で<br />
        支えます
      </span>
      <span class="hidden sm:inline">
        住み慣れた場所での<br />
        <span class="text-accent dark:text-white highlight">療養生活</span>を<br />
        しっかり支えます
      </span>
    </Fragment>
    <Fragment slot="subtitle">
      <span class="sm:hidden">
        大阪市内で、ご自宅・入居施設へ医師が定期訪問する<strong>訪問診療専門クリニック</strong>です。<br /><br />
        内科・精神科・小児科に対応し、急な変化のときは<strong>24時間365日の緊急往診</strong>も承ります。
      </span>
      <span class="hidden sm:inline">
        大阪市内でご自宅・施設へ医師が定期訪問し、診察・処方・検査を行う<strong>訪問診療専門クリニック</strong>です。<br /><br />
        内科・精神科・小児科に対応し、急な変化のときは<strong>24時間365日の緊急往診</strong>も承ります。
      </span>
