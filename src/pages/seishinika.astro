---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import PageTocNav from '~/components/ui/PageTocNav.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Content from '~/components/widgets/Content.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import {
  clinicalAnchorScrollMargin,
  clinicalHeroSubtitleClass,
  clinicalHeroTaglineClass,
  clinicalHeroTitleClass,
  clinicalSectionHeadline,
} from '~/constants/clinical-page-ui';
import { CLINIC_CONTACT } from '~/data/clinic-contact';
import { seishinikaFaqEntries } from '~/data/faq-seishinika';
import { seishinikaMedicalConditionGraph } from '~/data/seishinika-structured-data';
import { getPermalink } from '~/utils/permalinks';
import { buildFaqPageJsonLd, faqEntriesToWidgetItems } from '~/utils/seo-faq';
import { twMerge } from 'tailwind-merge';
import { serializeJsonLdForScript } from '~/utils/json-ld-script';

const metadata = {
  title: '精神科の訪問診療・オンライン診療｜大阪市｜かもめクリニック',
  description:
    '大阪市の精神科訪問診療。精神科専門医3名常勤（精神保健指定医在籍）。うつ病・統合失調症・認知症・引きこもり・双極性障害に対応。厚生労働省の指針に基づき要件を満たす場合、精神疾患の初診からオンライン診療に対応。在支診1認定。',
  ignoreTitleTemplate: true,
  openGraph: {
    type: 'website',
    /** adaptOpenGraphImages（外部URL・Unpic）の出力に合わせる */
    images: [{ url: 'https://kamome-clinic.net/images/top/slider02.jpg', width: 1200, height: 626 }],
  },
};

const jsonLdBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'トップページ', item: 'https://kamome-clinic.net/' },
    {
      '@type': 'ListItem',
      position: 2,
      name: '精神科の訪問診療・オンライン診療',
      item: 'https://kamome-clinic.net/seishinika',
    },
  ],
};

const jsonLdFAQ = buildFaqPageJsonLd(seishinikaFaqEntries);
const seishinikaFaqWidgetItems = faqEntriesToWidgetItems(seishinikaFaqEntries);

const doctorsHref = getPermalink('/doctors');
const contactHref = getPermalink('/renkei');
---

<Layout metadata={metadata}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={serializeJsonLdForScript(jsonLdBreadcrumb)} />
    <script type="application/ld+json" set:html={serializeJsonLdForScript(jsonLdFAQ)} />
    <script type="application/ld+json" set:html={serializeJsonLdForScript(seishinikaMedicalConditionGraph)} />
  </Fragment>

  <!-- Hero -->
  <Hero
    tagline="精神科 訪問診療・オンライン診療｜大阪市"
    taglineClass={clinicalHeroTaglineClass}
    titleClass={clinicalHeroTitleClass}
    subtitleClass={clinicalHeroSubtitleClass}
    sectionPaddingClass="pt-8 md:pt-14 pb-3 md:pb-4"
    textBlockPaddingClass="pb-2 md:pb-3"
  >
    <Fragment slot="title">
      外に出られなくても<br />
      <span class="text-primary dark:text-blue-300">精神科</span>の<br />
      診療を受けられます
    </Fragment>
    <Fragment slot="subtitle">
      <span class="hero-subtitle block mb-2 font-semibold text-primary dark:text-blue-300">
        精神科専門医3名常勤｜精神保健指定医・医学博士在籍の訪問診療体制
      </span>
      <span class="block mb-2">
        <span class="sm:hidden">
          外出困難な方・引きこもりの方・認知症の方のご自宅や施設へ専門医が伺います。<br />
          厚生労働省の指針に基づき要件を満たす場合、<strong class="text-gray-900 dark:text-gray-100">初診からオンライン診療</strong>にも対応します。
        </span>
        <span class="hidden sm:inline">
          通院困難な方・引きこもりの方・認知症の方のご自宅や施設へ、専門医が直接伺います。<br />
          厚生労働省の指針に基づき要件を満たす場合、<strong class="text-gray-900 dark:text-gray-100">精神疾患の初診からオンライン診療にも対応</strong>します。
        </span>
      </span>
      <span class="block text-xs text-gray-500 dark:text-gray-400">
        精神保健指定医・医学博士・日本神経精神学会専門医が在籍
      </span>
      <span class="block text-xs text-gray-500 dark:text-gray-400 mt-2 leading-relaxed">
        <a href={doctorsHref} class="text-primary underline">医師紹介</a>で体制の詳細をご確認ください。
      </span>
    </Fragment>
  </Hero>

  <PageTocNav
    ariaLabel="このページの主な内容"
    items={[
      { href: '#first-step', label: 'まずはご相談' },
      { href: '#visit-vs-online', label: '訪問・オンラインの違い' },
      { href: '#diseases', label: '対応疾患' },
      { href: '#target', label: '対象' },
      { href: '#online', label: 'オンライン診療' },
      { href: '#faq', label: 'よくある質問' },
    ]}
  />

  <!-- 次の一歩（相談導線） -->
  <Features
    id="first-step"
    scrollMarginClass={clinicalAnchorScrollMargin}
    tagline="ご利用の流れ"
    title="まずはご相談から"
    subtitle="診療の有無を決める前に、お電話・フォームでお困りごとをお聞かせください。画面下のボタンからもいつでも操作できます。"
    columns={2}
    classes={{
      headline: { ...clinicalSectionHeadline },
      container: 'max-w-7xl mx-auto pt-2 md:pt-3 pb-8 md:pb-14 lg:pb-16',
    }}
    items={[
      {
        title: 'お電話',
        description: `平日・祝日 ${CLINIC_CONTACT.hoursPrimary}に、看護師・事務が初回のご相談をお受けします。`,
        icon: 'tabler:phone',
        callToAction: {
          variant: 'floatingCtaTel' as const,
          text: CLINIC_CONTACT.telDisplay,
          href: CLINIC_CONTACT.telHref,
          icon: 'tabler:phone',
        },
      },
      {
        title: 'お問い合わせフォーム',
        description: 'ご都合のよい時間に、内容を整理して送信いただけます。',
        icon: 'tabler:clipboard-list',
        callToAction: {
          variant: 'floatingCtaForm' as const,
          text: '問い合わせフォーム',
          href: contactHref,
          icon: 'tabler:clipboard-list',
        },
      },
    ]}
  />

  <!-- 訪問とオンラインの違い -->
  <Features
    id="visit-vs-online"
    scrollMarginClass={clinicalAnchorScrollMargin}
    tagline="受け方の選択"
    title="訪問診療とオンライン診療の違い"
    subtitle="状況に応じて併用・切り替えも可能です。詳しいオンラインの手順は下のセクションでもご案内しています。"
    columns={2}
    classes={{ headline: { ...clinicalSectionHeadline }, container: 'max-w-7xl mx-auto' }}
    items={[
      {
        title: '訪問診療',
        description:
          '精神科専門医がご自宅・施設へ伺い、対面で診察・処方・状態確認を行います。通院が困難な方、身体合併や認知症で対面評価が望ましい方に適しています。',
        icon: 'tabler:home-heart',
      },
      {
        title: 'オンライン診療',
        description:
          'スマートフォンやパソコンのビデオ通話で受診します。2022年の厚生労働省指針改訂により、要件を満たす場合は精神疾患の初診から利用できます。外出恐怖や交通手段のない方の第一歩にも適しています。',
        icon: 'tabler:video',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features>

  <!-- 対応する疾患 -->
  <Features
    id="diseases"
    scrollMarginClass={clinicalAnchorScrollMargin}
    tagline="対応疾患"
    title="こんな疾患・状態に対応しています"
    subtitle="専門医が継続的に診療。処方・調整・ご家族への指導も行います。"
    classes={{ headline: { ...clinicalSectionHeadline } }}
    items={[
      {
        title: 'うつ病・抑うつ状態',
        description:
          '気力がわかない・外出できない・家族の支えで何とか生活している方に訪問診療は適しています。薬物療法と生活指導を継続的に行います。',
        icon: 'tabler:mood-sad',
      },
      {
        title: '統合失調症',
        description:
          '長期にわたる通院が必要な方も、ご自宅で定期的な診療・処方・状態確認が可能です。再発予防と服薬管理をサポートします。',
        icon: 'tabler:brain',
      },
      {
        title: '双極性障害',
        description:
          '薬で気分の波を安定させながら、在宅生活を継続できるようサポートします。躁状態・うつ状態の変動にも迅速に対応します。',
        icon: 'tabler:activity',
      },
      {
        title: '認知症（BPSDを含む）',
        description:
          'アルツハイマー型・レビー小体型・血管性認知症など。徘徊・暴言・妄想などBPSDへの薬物調整も精神科専門医が担当します。',
        icon: 'tabler:user-heart',
      },
      {
        title: 'アルコール・薬物依存症',
        description: '依存症の継続治療・断酒支援を在宅で行います。専門医が丁寧に関わり、ご家族も含めてサポートします。',
        icon: 'tabler:droplet-off',
      },
      {
        title: '引きこもり・社会不安',
        description:
          '外出への強い不安や恐怖がある方も、オンライン診療や訪問診療からスタートできます。ご家族のみのご相談も可能です。',
        icon: 'tabler:home',
      },
      {
        title: 'PTSD・解離性障害',
        description:
          'トラウマ体験による心の傷に、専門医が安全な環境（ご自宅）で継続的に関わります。焦らずゆっくり取り組めます。',
        icon: 'tabler:heart-handshake',
      },
      {
        title: '発達障害（ADHD・ASD）',
        description:
          '診断・薬物療法・日常生活の工夫まで対応。成人の発達障害にも対応しており、職場・生活上の困り事を一緒に整理します。',
        icon: 'tabler:puzzle',
      },
    ]}
  />

  <!-- 対象者 -->
  <Features2
    id="target"
    scrollMarginClass={clinicalAnchorScrollMargin}
    tagline="こんな方へ"
    title="精神科の訪問診療をご検討ください"
    classes={{ headline: { ...clinicalSectionHeadline }, container: 'max-w-7xl mx-auto' }}
    items={[
      {
        title: '外来受診をやめてしまった方',
        description: '通院が途切れ、薬も切れかけている方の治療再開を一緒に始めます。中断していた期間は問いません。',
        icon: 'tabler:refresh',
      },
      {
        title: '認知症で外来受診が困難な方',
        description:
          '興奮・混乱・拒否が強くなり外来通院が難しくなった方をご自宅で診察します。施設入居中の方も対応します。',
        icon: 'tabler:user-heart',
      },
      {
        title: '引きこもりのご家族を心配している方',
        description: 'ご本人が受診を拒否している場合も、まずご家族だけでご相談ください。状況に応じてアプローチします。',
        icon: 'tabler:users',
      },
      {
        title: '精神科的問題を抱えた高齢者',
        description: '老年期うつ・認知症BPSD・夜間の問題行動など、施設入居中の方を含めて精神科専門医が対応します。',
        icon: 'tabler:building',
      },
      {
        title: '精神科病院から退院し在宅療養中の方',
        description: '退院後に地域での生活を続けるためのサポートを、訪問診療で継続します。',
        icon: 'tabler:home',
      },
      {
        title: '内科疾患と精神科治療が両方必要な方',
        description: '内科・精神科を同時に抱える方も、かもめクリニックなら1つのクリニックで一体的に対応できます。',
        icon: 'tabler:stethoscope',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- オンライン診療（詳細） -->
  <Content
    id="online"
    scrollMarginClass={clinicalAnchorScrollMargin}
    tagline="オンライン診療"
    title="厚生労働省の指針に基づき、要件を満たす場合に初診からオンライン診療に対応します"
    isReversed
    classes={{
      headline: {
        ...clinicalSectionHeadline,
        container: twMerge('max-w-xl sm:mx-auto lg:max-w-2xl text-left sm:text-center', clinicalSectionHeadline.container),
      },
    }}
    items={[
      {
        title: '2022年法改正により要件を満たす場合に初診から対応可能に',
        description:
          '従来は再診のみでしたが、2022年の厚生労働省指針改訂により、一定の要件を満たす場合に限り精神疾患の初診からオンライン診療が認められています。詳細はお電話・フォームにてご確認ください。',
      },
      {
        title: 'スマホ・PCで受診できる',
        description:
          'ビデオ通話で医師と対面診療。通院・外出不要で診察・処方が受けられます。処方箋は薬局への直送も可能です。',
      },
      {
        title: 'こんな方に向いています',
        description:
          '外出恐怖のある方・交通手段がない方・対面が不安な方・遠方の親御さんを心配されている方などに適しています。',
      },
      {
        title: '訪問診療への移行も可能',
        description: 'まずオンラインで診療を開始し、状況に応じて訪問診療に切り替えることもできます。柔軟に対応します。',
      },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        自宅にいながら精神科医に相談できます
      </h3>
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- 命の危機・緊急時 -->
  <section
    class="max-w-4xl mx-auto px-4 sm:px-6 py-10 text-sm text-gray-600 dark:text-gray-300 leading-relaxed border-t border-gray-200 dark:border-slate-700"
    aria-label="緊急時のご案内"
  >
    <p class="mb-0">
      ご自身や身近な方に<strong class="text-gray-800 dark:text-gray-100">命の危機</strong>や<strong
        class="text-gray-800 dark:text-gray-100">自殺念慮</strong
      >がある場合は、まず<strong>110・119</strong>や、お住まいの地域のいのちの電話・救急医療をご利用ください。
    </p>
  </section>

  <!-- FAQ -->
  <FAQs
    id="faq"
    scrollMarginClass={clinicalAnchorScrollMargin}
    title="精神科訪問診療 よくある質問"
    tagline="FAQ"
    classes={{ container: 'max-w-6xl', headline: { ...clinicalSectionHeadline } }}
    items={seishinikaFaqWidgetItems}
  />
</Layout>
