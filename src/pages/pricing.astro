---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import {
  clinicalHeroSubtitleClass,
  clinicalHeroTaglineClass,
  clinicalHeroTitleClass,
  ctaHeroPrimaryClass,
} from '~/constants/clinical-page-ui';

// /pricing は /cost へ誘導する薄いページ。noindex + canonical で重複評価を回避する
const metadata = {
  title: '料金・費用のご案内｜かもめクリニック（大阪市・訪問診療）',
  description:
    '訪問診療の料金は健康保険・介護保険の適用により、負担割合やご年齢によって異なります。詳しい目安は費用・保険ページをご覧ください。',
  ignoreTitleTemplate: true,
  robots: {
    index: false,
    follow: true,
  },
  canonical: 'https://kamome-clinic.net/cost',
  openGraph: {
    type: 'website',
    images: [{ url: 'https://kamome-clinic.net/images/top/slider02.jpg', width: 1400, height: 500 }],
  },
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="料金について"
    taglineClass={clinicalHeroTaglineClass}
    titleClass={clinicalHeroTitleClass}
    subtitleClass={clinicalHeroSubtitleClass}
  >
    <Fragment slot="title">訪問診療の<br />料金・費用について</Fragment>
    <Fragment slot="subtitle">
      かもめクリニックの訪問診療は<strong>健康保険・介護保険が適用</strong>されます。窓口負担はご加入の保険・年齢・所得によって異なります。目安や制度の概要は「費用・保険」ページでわかりやすく解説しています。
    </Fragment>
  </Hero>

  <section class="py-12 md:py-16 bg-gray-50 dark:bg-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="max-w-3xl mx-auto text-center space-y-6">
        <p class="text-sm md:text-base text-gray-700 dark:text-gray-300 leading-relaxed">
          診療報酬は国の定めに基づきます。在支診1（機能強化型在宅療養支援診療所）としての加算がある一方、患者さまの<strong>窓口負担（1〜3割など）</strong>の考え方は一般的な保険診療と同様です。生活保護の方は医療扶助により自己負担なく受診できます。
        </p>
        <a href="/cost" class:list={[ctaHeroPrimaryClass, 'inline-flex']}> 費用・保険の詳細を見る </a>
        <p class="text-xs text-gray-500 dark:text-gray-400">
          ご不明点はお電話（06-4301-7871）でもご説明いたします。
        </p>
      </div>
    </div>
  </section>

</Layout>
