---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { Icon } from 'astro-icon/components';

const WP_BLOG_BASE = 'https://www.kamome-clinic.net/blog';
const WP_REST = `${WP_BLOG_BASE}/index.php?rest_route=`;

type WPPost = {
  id: number;
  date: string;
  link: string;
  title: { rendered: string };
  excerpt: { rendered: string };
  categories: number[];
};

type WPCategory = { id: number; name: string };

type ArchiveMonth = {
  year: number;
  month: number;
  count: number;
  /** WordPress 標準の月別アーカイブ（`?m=YYYYMM`） */
  archiveUrl: string;
};

function stripTags(html: string): string {
  return html
    .replace(/<[^>]+>/g, ' ')
    .replace(/&nbsp;/g, ' ')
    .replace(/&#8230;|\[…\]/g, '…')
    .replace(/\s+/g, ' ')
    .trim();
}

function decodeBasicEntities(text: string): string {
  return text
    .replace(/&amp;/g, '&')
    .replace(/&lt;/g, '<')
    .replace(/&gt;/g, '>')
    .replace(/&quot;/g, '"')
    .replace(/&#039;/g, "'");
}

/** ビルド時に全記事のメタだけ取得（ページネーション）。件数上限で打ち切り */
async function fetchAllPostsMeta(maxPages: number): Promise<WPPost[]> {
  const all: WPPost[] = [];
  for (let page = 1; page <= maxPages; page++) {
    const url = `${WP_REST}/wp/v2/posts&per_page=100&page=${page}&orderby=date&order=desc&_fields=id,date,link,title,excerpt,categories`;
    const res = await fetch(url);
    if (!res.ok) {
      if (page === 1) throw new Error(`posts ${res.status}`);
      break;
    }
    const batch = (await res.json()) as WPPost[];
    if (!Array.isArray(batch) || batch.length === 0) break;
    all.push(...batch);
    if (batch.length < 100) break;
  }
  return all;
}

function buildArchiveMonths(postsForArchive: WPPost[], blogBase: string): ArchiveMonth[] {
  const keyToCount = new Map<string, { year: number; month: number; count: number }>();
  for (const p of postsForArchive) {
    const d = new Date(p.date);
    if (Number.isNaN(d.getTime())) continue;
    const year = d.getFullYear();
    const month = d.getMonth() + 1;
    const key = `${year}-${month}`;
    const cur = keyToCount.get(key);
    if (cur) cur.count += 1;
    else keyToCount.set(key, { year, month, count: 1 });
  }
  const rows: ArchiveMonth[] = [];
  for (const { year, month, count } of keyToCount.values()) {
    const yyyymm = `${year}${String(month).padStart(2, '0')}`;
    rows.push({
      year,
      month,
      count,
      archiveUrl: `${blogBase}/?m=${yyyymm}`,
    });
  }
  rows.sort((a, b) => (a.year !== b.year ? b.year - a.year : b.month - a.month));
  return rows;
}

function groupArchiveByYear(months: ArchiveMonth[]): { year: number; months: ArchiveMonth[] }[] {
  const map = new Map<number, ArchiveMonth[]>();
  for (const m of months) {
    const list = map.get(m.year) ?? [];
    list.push(m);
    map.set(m.year, list);
  }
  const years = [...map.keys()].sort((a, b) => b - a);
  return years.map((year) => ({ year, months: map.get(year) ?? [] }));
}

let posts: WPPost[] = [];
let categoryById: Record<number, string> = {};
let archiveByYear: { year: number; months: ArchiveMonth[] }[] = [];
let loadError: string | null = null;

const LIST_LIMIT = 30;
const ARCHIVE_FETCH_MAX_PAGES = 50;

try {
  const [allMeta, catsRes] = await Promise.all([
    fetchAllPostsMeta(ARCHIVE_FETCH_MAX_PAGES),
    fetch(`${WP_REST}/wp/v2/categories&per_page=100&_fields=id,name`),
  ]);
  if (!catsRes.ok) throw new Error(`categories ${catsRes.status}`);
  const cats = (await catsRes.json()) as WPCategory[];
  if (!Array.isArray(cats)) throw new Error('invalid JSON');
  posts = allMeta.slice(0, LIST_LIMIT);
  archiveByYear = groupArchiveByYear(buildArchiveMonths(allMeta, WP_BLOG_BASE));
  for (const c of cats) categoryById[c.id] = c.name;
} catch (e) {
  console.warn('[blog] WordPress の取得に失敗しました:', e);
  loadError = e instanceof Error ? e.message : String(e);
}

const metadata = {
  title: '公式ブログ（お知らせ）｜かもめクリニック（大阪市）',
  description:
    'かもめクリニックのお知らせ・ブログ記事一覧。診療体制・休診・採用・地域連携などの最新情報を掲載しています。',
  ignoreTitleTemplate: true,
  openGraph: {
    type: 'website',
    images: [{ url: 'https://www.kamome-clinic.net/images/top/slider02.jpg', width: 1400, height: 500 }],
  },
};

const jsonLdBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'トップページ', item: 'https://kamome-clinic.net/' },
    { '@type': 'ListItem', position: 2, name: '公式ブログ', item: 'https://kamome-clinic.net/blog' },
  ],
};
---

<Layout metadata={metadata}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdBreadcrumb)} />
  </Fragment>

  <Hero
    tagline="お知らせ"
    image={{
      src: 'https://www.kamome-clinic.net/images/top/slider02.jpg',
      alt: 'かもめクリニック',
    }}
  >
    <Fragment slot="title">公式ブログ</Fragment>
    <Fragment slot="subtitle">
      かもめクリニックのお知らせ・ブログです。記事本文は従来どおり
      <a
        href={WP_BLOG_BASE}
        class="text-primary underline font-semibold hover:opacity-90"
        target="_blank"
        rel="noopener noreferrer">公式サイトのブログ</a
      >
      でご覧いただけます。
    </Fragment>
  </Hero>

  <section class="py-12 md:py-16 bg-white dark:bg-slate-900">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="lg:grid lg:grid-cols-[1fr_minmax(0,17rem)] lg:gap-10 xl:gap-12 lg:items-start">
        <div class="min-w-0">
          {
            loadError && (
              <div class="rounded-xl border border-amber-200 bg-amber-50 dark:bg-amber-950/30 dark:border-amber-800 p-5 mb-8 text-amber-900 dark:text-amber-100">
                <p class="font-bold mb-2">記事一覧を自動取得できませんでした</p>
                <p class="text-sm opacity-90 mb-3">
                  ビルド時に WordPress
                  からデータを読み込めなかった可能性があります。お手数ですが、下記から直接ご覧ください。
                </p>
                <a
                  href={WP_BLOG_BASE}
                  class="inline-flex items-center gap-2 text-sm font-bold text-primary underline"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {WP_BLOG_BASE}/ <Icon name="tabler:external-link" class="w-4 h-4" />
                </a>
              </div>
            )
          }

          {
            !loadError && posts.length === 0 && (
              <p class="text-center text-gray-600 dark:text-gray-400">表示できる記事がありません。</p>
            )
          }

          <ul class="flex flex-col gap-6">
            {
              posts.map((post) => {
                const title = decodeBasicEntities(stripTags(post.title.rendered));
                const excerpt = decodeBasicEntities(stripTags(post.excerpt.rendered));
                const d = new Date(post.date);
                const dateStr = d.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' });
                const catNames = post.categories.map((id) => categoryById[id]).filter(Boolean);
                return (
                  <li>
                    <article class="rounded-2xl border border-gray-100 dark:border-slate-700 bg-blue-50/40 dark:bg-slate-800/50 p-6 shadow-sm hover:border-primary/30 transition-colors">
                      <time class="text-sm text-gray-500 dark:text-gray-400 block mb-2" datetime={post.date}>
                        {dateStr}
                      </time>
                      {catNames.length > 0 && (
                        <ul class="flex flex-wrap gap-2 mb-3">
                          {catNames.map((name) => (
                            <li>
                              <span class="text-xs font-semibold px-2.5 py-0.5 rounded-full bg-white dark:bg-slate-700 border border-gray-200 dark:border-slate-600 text-gray-600 dark:text-gray-300">
                                {name}
                              </span>
                            </li>
                          ))}
                        </ul>
                      )}
                      <h2 class="text-xl font-bold text-gray-900 dark:text-white leading-snug mb-3">
                        <a
                          href={post.link}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="hover:text-primary transition-colors inline-flex items-start gap-1"
                        >
                          {title}
                          <Icon
                            name="tabler:external-link"
                            class="w-5 h-5 shrink-0 text-primary mt-0.5"
                            aria-hidden="true"
                          />
                        </a>
                      </h2>
                      {excerpt && (
                        <p class="text-sm text-gray-600 dark:text-gray-300 leading-relaxed line-clamp-4">{excerpt}</p>
                      )}
                      <a
                        href={post.link}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-1 mt-4 text-sm font-bold text-primary hover:underline"
                      >
                        記事を読む
                        <Icon name="tabler:arrow-right" class="w-4 h-4" />
                      </a>
                    </article>
                  </li>
                );
              })
            }
          </ul>

          <div class="mt-12 text-center">
            <a
              href={`${WP_BLOG_BASE}/`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 border-2 border-primary text-primary font-bold px-6 py-3 rounded-full hover:bg-primary hover:text-white transition-colors"
            >
              すべての記事・アーカイブ（公式ブログ）
              <Icon name="tabler:external-link" class="w-5 h-5" />
            </a>
            <p class="text-xs text-gray-500 dark:text-gray-400 mt-4">
              一覧はビルド時点の最新 {LIST_LIMIT} 件です。右のアーカイブは取得できた範囲の月別まとめです。ページ送り・検索は公式ブログをご利用ください。
            </p>
          </div>
        </div>

        <aside
          class="mt-12 lg:mt-0 lg:sticky lg:top-24 rounded-2xl border border-gray-100 dark:border-slate-700 bg-slate-50/80 dark:bg-slate-800/40 p-5 shadow-sm"
          aria-label="月別アーカイブ"
        >
          <h2
            class="text-sm font-bold text-gray-900 dark:text-white uppercase tracking-wide mb-4 flex items-center gap-2"
          >
            <Icon name="tabler:calendar-month" class="w-5 h-5 text-primary shrink-0" aria-hidden="true" />
            アーカイブ
          </h2>
          {
            loadError ? (
              <p class="text-xs text-gray-600 dark:text-gray-400 leading-relaxed">
                取得できなかったため表示できません。
                <a
                  href={WP_BLOG_BASE}
                  class="text-primary font-semibold underline mt-2 inline-block"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  公式ブログで開く
                </a>
              </p>
            ) : archiveByYear.length === 0 ? (
              <p class="text-xs text-gray-600 dark:text-gray-400">アーカイブ情報がありません。</p>
            ) : (
              <nav class="max-h-[min(70vh,32rem)] overflow-y-auto pr-1 -mr-1 space-y-5">
                {archiveByYear.map(({ year, months }) => (
                  <div>
                    <p class="text-xs font-bold text-gray-500 dark:text-gray-400 mb-2">{year}年</p>
                    <ul class="space-y-1.5 border-l-2 border-primary/25 pl-3">
                      {months.map((m) => (
                        <li>
                          <a
                            href={m.archiveUrl}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-sm text-gray-800 dark:text-gray-200 hover:text-primary dark:hover:text-primary transition-colors inline-flex items-center gap-1 flex-wrap"
                          >
                            {m.month}月
                            <span class="text-xs text-gray-500 dark:text-gray-400 font-normal">（{m.count}件）</span>
                            <Icon
                              name="tabler:external-link"
                              class="w-3.5 h-3.5 shrink-0 opacity-70"
                              aria-hidden="true"
                            />
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </nav>
            )
          }
          {
            !loadError && archiveByYear.length > 0 && (
              <p class="text-[11px] text-gray-500 dark:text-gray-400 mt-4 leading-relaxed border-t border-gray-200 dark:border-slate-600 pt-3">
                月のリンクは公式ブログの月別一覧へ移動します。記事が {ARCHIVE_FETCH_MAX_PAGES * 100}{' '}
                件を超える場合は先頭の取得分のみ反映されます。
              </p>
            )
          }
        </aside>
      </div>
    </div>
  </section>

  <CallToAction
    actions={[
      { variant: 'primary', text: 'お電話でのご相談（06-4301-7871）', href: 'tel:0643017871', icon: 'tabler:phone' },
      {
        variant: 'line',
        text: 'LINEで無料相談',
        href: 'https://line.me/R/ti/p/%40512ysmzx',
        icon: 'tabler:brand-line',
      },
    ]}
  >
    <Fragment slot="title">訪問診療のご相談はこちら</Fragment>
    <Fragment slot="subtitle"> 受付：平日 9:00〜17:00 | LINE（@512ysmzx）は24時間受付 </Fragment>
  </CallToAction>
</Layout>
