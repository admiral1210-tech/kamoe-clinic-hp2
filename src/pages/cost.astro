---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import PageSectionHeading from '~/components/ui/PageSectionHeading.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import { Icon } from 'astro-icon/components';
import { twMerge } from 'tailwind-merge';
import {
  clinicalHeroSubtitleClass,
  clinicalHeroTaglineClass,
  clinicalHeroTitleClass,
  clinicalSectionHeadline,
} from '~/constants/clinical-page-ui';
import { costFaqEntries } from '~/data/faq-cost';
import { buildFaqPageJsonLd, faqEntriesToWidgetItems } from '~/utils/seo-faq';
import { serializeJsonLdForScript } from '~/utils/json-ld-script';

const metadata = {
  title: '訪問診療の費用・料金・保険適用｜かもめクリニック（大阪市）',
  description:
    'かもめクリニックの訪問診療にかかる費用・料金の目安。医療保険・後期高齢者医療・生活保護への対応、自己負担額の目安をわかりやすく解説します。',
  ignoreTitleTemplate: true,
  openGraph: {
    type: 'website',
    images: [{ url: 'https://kamome-clinic.net/images/top/slider02.jpg', width: 1400, height: 500 }],
  },
};

// JSON-LD: BreadcrumbList
const jsonLdBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'トップページ', item: 'https://kamome-clinic.net/' },
    { '@type': 'ListItem', position: 2, name: '訪問診療の費用・保険', item: 'https://kamome-clinic.net/cost' },
  ],
};

const jsonLdFAQ = buildFaqPageJsonLd(costFaqEntries);
const costFaqWidgetItems = faqEntriesToWidgetItems(costFaqEntries);

// JSON-LD: Speakable
const jsonLdSpeakable = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': 'https://kamome-clinic.net/cost',
  name: '訪問診療の費用・料金・保険適用｜かもめクリニック',
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['h1', 'h2'],
  },
  url: 'https://kamome-clinic.net/cost',
};
---

<Layout metadata={metadata}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={serializeJsonLdForScript(jsonLdBreadcrumb)} />
    <script type="application/ld+json" set:html={serializeJsonLdForScript(jsonLdFAQ)} />
    <script type="application/ld+json" set:html={serializeJsonLdForScript(jsonLdSpeakable)} />
  </Fragment>

  <Hero
    tagline="費用・保険｜大阪市の訪問診療"
    taglineClass={clinicalHeroTaglineClass}
    titleClass={clinicalHeroTitleClass}
    subtitleClass={clinicalHeroSubtitleClass}
  >
    <Fragment slot="title">
      訪問診療の<br />
      <span class="text-primary dark:text-blue-300">費用・保険</span>について
    </Fragment>
    <Fragment slot="subtitle">
      かもめクリニックの訪問診療は<strong>医療保険が適用</strong>されます。<br class="hidden sm:inline" />
      75歳以上の後期高齢者は1〜2割負担、生活保護の方は自己負担ゼロで受けられます。
    </Fragment>
  </Hero>

  <!-- 保険の種類 -->
  <Features
    tagline="保険について"
    title="訪問診療に適用できる保険制度"
    subtitle="複数の制度が組み合わさることで、自己負担を軽減できます"
    classes={{ headline: { ...clinicalSectionHeadline } }}
    items={[
      {
        title: '医療保険',
        description:
          '訪問診療の診察料・処方料・管理料などが医療保険の対象です。国民健康保険・社会保険・後期高齢者医療保険のいずれも適用されます。',
        icon: 'tabler:heart-handshake',
      },
      {
        title: '後期高齢者医療保険',
        description:
          '75歳以上の方は自動的に後期高齢者医療保険に加入します。所得に応じて1割または2割負担となり、医療費の自己負担が軽減されます。',
        icon: 'tabler:user-heart',
      },
      {
        title: '高額療養費制度',
        description:
          '1か月の医療費自己負担が一定額を超えた場合、超過分が払い戻される制度です。70歳以上は自己負担限度額が低く設定されています。加入保険に申請が必要です。',
        icon: 'tabler:cash-banknote',
      },
      {
        title: '生活保護',
        description:
          '生活保護受給中の方は医療扶助が適用され、自己負担ゼロで訪問診療を受けられます。事前に福祉事務所で医療券を取得する必要があります。',
        icon: 'tabler:shield-check',
      },
      {
        title: '障害者医療費助成',
        description:
          '身体障害者手帳・精神障害者保健福祉手帳をお持ちの方は、自治体の医療費助成制度（マル障等）が適用される場合があります。お住まいの区役所にご確認ください。',
        icon: 'tabler:accessible',
      },
    ]}
  />

  <!-- 医療費シミュレーション -->
  <section id="simulator" class="py-16 dark:bg-slate-800 scroll-mt-32">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <PageSectionHeading
        tagline="シミュレーション"
        title="医療費シミュレーション"
        subtitle="4つの質問に答えるだけで、月々の自己負担の目安がわかります。"
      />

      <div
        class="bg-white dark:bg-slate-800 rounded-2xl shadow-md p-6 md:p-8 border border-blue-100 dark:border-slate-700"
      >
        <div class="mb-6">
          <p class="font-bold text-gray-800 dark:text-white mb-3 flex items-center gap-2 text-lg">
            <span
              class="bg-primary text-white text-sm font-bold w-7 h-7 rounded-lg flex items-center justify-center shrink-0"
              >1</span
            >
            保険の種類を教えてください
          </p>
          <div class="grid grid-cols-2 gap-2" id="fee-insurance">
            {
              [
                { v: 'kouki', l: '後期高齢者医療', s: '75歳以上' },
                { v: 'korei', l: '高齢者医療', s: '70〜74歳' },
                { v: 'ippan', l: '一般医療保険', s: '70歳未満' },
                { v: 'seikatsu', l: '生活保護受給', s: '' },
              ].map(({ v, l, s }) => (
                <label class="fee-option cursor-pointer">
                  <input type="radio" name="insurance" value={v} class="sr-only" />
                  <div class="fee-btn border-2 border-gray-200 rounded-xl p-3 text-center font-medium text-gray-700 dark:text-gray-200 hover:border-primary transition-colors">
                    {l}
                    {s && (
                      <>
                        <br />
                        <span class="text-sm font-normal text-gray-500">{s}</span>
                      </>
                    )}
                  </div>
                </label>
              ))
            }
          </div>
        </div>
        <div class="mb-6" id="step2-wrap" style="display:none">
          <p class="font-bold text-gray-800 dark:text-white mb-3 flex items-center gap-2 text-lg">
            <span
              class="bg-primary text-white text-sm font-bold w-7 h-7 rounded-lg flex items-center justify-center shrink-0"
              >2</span
            >
            自己負担割合を選んでください
          </p>
          <p class="text-sm text-gray-500 mb-3">保険証に記載されています。</p>
          <div class="flex gap-2" id="fee-ratio">
            {
              ['1割', '2割', '3割'].map((r) => (
                <label class="fee-option flex-1 cursor-pointer">
                  <input type="radio" name="ratio" value={r} class="sr-only" />
                  <div class="fee-btn border-2 border-gray-200 rounded-xl p-3 text-center font-bold text-gray-700 dark:text-gray-200 hover:border-primary transition-colors text-lg">
                    {r}
                  </div>
                </label>
              ))
            }
          </div>
        </div>
        <div class="mb-6" id="step3-wrap" style="display:none">
          <p class="font-bold text-gray-800 dark:text-white mb-3 flex items-center gap-2 text-lg">
            <span
              class="bg-primary text-white text-sm font-bold w-7 h-7 rounded-lg flex items-center justify-center shrink-0"
              >3</span
            >
            お住まいの場所を選んでください
          </p>
          <div class="grid grid-cols-2 gap-2" id="fee-place">
            {
              [
                { v: 'jitaku', l: 'ご自宅', s: '一戸建て・マンションなど' },
                { v: 'gh', l: 'グループホーム', s: '認知症の方の共同施設' },
                { v: 'tokuteishisetsu', l: '特定施設', s: '有料老人ホーム・サ高住など' },
                { v: 'kaigo', l: '介護老人施設', s: '特養・老健など' },
              ].map(({ v, l, s }) => (
                <label class="fee-option cursor-pointer">
                  <input type="radio" name="place" value={v} class="sr-only" />
                  <div class="fee-btn border-2 border-gray-200 rounded-xl p-3 text-center font-medium text-gray-700 dark:text-gray-200 hover:border-primary transition-colors">
                    {l}
                    <br />
                    <span class="text-sm font-normal text-gray-500">{s}</span>
                  </div>
                </label>
              ))
            }
          </div>
        </div>
        <div class="mb-6" id="step4-wrap" style="display:none">
          <p class="font-bold text-gray-800 dark:text-white mb-3 flex items-center gap-2 text-lg">
            <span
              class="bg-primary text-white text-sm font-bold w-7 h-7 rounded-lg flex items-center justify-center shrink-0"
              >4</span
            >
            診療の内容を選んでください
          </p>
          <div class="grid grid-cols-2 gap-2" id="fee-content">
            {
              [
                { v: 'basic', l: '診察・処方のみ', s: '定期訪問とお薬の処方' },
                { v: 'psych', l: '精神科診療あり', s: '精神科専門医による加算' },
                { v: 'treat', l: '医療処置あり', s: '胃ろう・カテーテル等の管理' },
                { v: 'capd', l: '在宅透析・高度医療あり', s: '腹膜透析（CAPD）を実施中' },
              ].map(({ v, l, s }) => (
                <label class="fee-option cursor-pointer">
                  <input type="radio" name="content" value={v} class="sr-only" />
                  <div class="fee-btn border-2 border-gray-200 rounded-xl p-3 text-center font-medium text-gray-700 dark:text-gray-200 hover:border-primary transition-colors">
                    {l}
                    <br />
                    <span class="text-sm font-normal text-gray-500">{s}</span>
                  </div>
                </label>
              ))
            }
          </div>
        </div>
        <div id="calc-btn-wrap" style="display:none">
          <button
            id="fee-calc-btn"
            class="w-full bg-primary text-white font-bold py-4 rounded-xl hover:opacity-90 transition-opacity text-lg"
            >月々の目安を計算する</button
          >
        </div>
        <div id="fee-result" class="mt-6 hidden">
          <div
            class="bg-blue-50 dark:bg-slate-700 rounded-xl p-6 text-center border border-blue-200 dark:border-slate-600"
          >
            <p class="text-gray-600 dark:text-gray-300 mb-2">月々の自己負担目安（診療料のみ）</p>
            <p class="text-5xl font-black text-primary mb-2" id="fee-amount">-</p>
            <p class="text-sm text-gray-500">※ 薬代・処置・検査費用は別途加算されます</p>
          </div>

          <!-- 費用内訳の折りたたみ -->
          <div class="mt-4">
            <button
              id="fee-breakdown-btn"
              class="w-full flex items-center justify-between px-4 py-3 bg-gray-50 hover:bg-gray-100 border border-gray-200 rounded-xl text-sm font-medium text-gray-700 transition-colors"
              aria-expanded="false"
              aria-controls="fee-breakdown"
            >
              <span>費用の内訳を確認する</span>
              <Icon name="tabler:chevron-down" class="w-5 h-5 transition-transform duration-200" id="fee-breakdown-icon" />
            </button>
            <div id="fee-breakdown" class="hidden mt-2 rounded-xl border border-gray-100 overflow-hidden text-sm">
              <table class="w-full">
                <thead>
                  <tr class="bg-gray-50 text-gray-500 text-left">
                    <th class="px-4 py-2 font-medium">費用項目</th>
                    <th class="px-4 py-2 font-medium text-right">点数目安</th>
                    <th class="px-4 py-2 font-medium text-right">備考</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 text-gray-700">
                  <tr>
                    <td class="px-4 py-3">在宅患者訪問診療料</td>
                    <td class="px-4 py-3 text-right">888点/回×月2回</td>
                    <td class="px-4 py-3 text-right text-gray-500">在支診1の場合</td>
                  </tr>
                  <tr class="bg-gray-50">
                    <td class="px-4 py-3">在宅時医学総合管理料</td>
                    <td class="px-4 py-3 text-right">5,385点/月</td>
                    <td class="px-4 py-3 text-right text-gray-500">ご自宅・月2回の場合</td>
                  </tr>
                  <tr>
                    <td class="px-4 py-3">処方箋料</td>
                    <td class="px-4 py-3 text-right">68点/回</td>
                    <td class="px-4 py-3 text-right text-gray-500">薬は薬局で別途</td>
                  </tr>
                  <tr class="bg-gray-50">
                    <td class="px-4 py-3">薬剤費・調剤料</td>
                    <td class="px-4 py-3 text-right" colspan="2">処方内容により異なります（薬局でのお支払い）</td>
                  </tr>
                  <tr>
                    <td class="px-4 py-3">検査・処置費</td>
                    <td class="px-4 py-3 text-right" colspan="2">必要に応じて加算（採血・心電図など）</td>
                  </tr>
                </tbody>
              </table>
              <p class="px-4 py-3 text-xs text-gray-500 bg-gray-50 border-t border-gray-100">
                ※ 上記は2024年度診療報酬に基づく参考値です。実際の点数は算定条件により異なります。
              </p>
            </div>
          </div>

          <p class="mt-4 text-center text-gray-600 dark:text-gray-300">
            詳しくはお電話またはお問い合わせフォームでご説明します。
            <a href="tel:0643017871" class="text-primary font-bold hover:underline inline-flex items-center gap-1">
              <Icon name="tabler:phone" class="w-5 h-5" /> 06-4301-7871
            </a>
          </p>
        </div>
      </div>
      <p class="text-center mt-4 text-sm text-gray-500">
        ※ 上記はあくまでも目安です。実際の費用は保険の種類・加算・処置内容により異なります。
      </p>
    </div>
  </section>

  <script is:inline>
    (function () {
      const table = {
        kouki: {
          '1割': { jitaku: [5000, 8000], gh: [3000, 5000], tokuteishisetsu: [3000, 5000], kaigo: [2000, 4000] },
          '2割': { jitaku: [10000, 16000], gh: [6000, 10000], tokuteishisetsu: [6000, 10000], kaigo: [4000, 8000] },
          '3割': { jitaku: [15000, 24000], gh: [9000, 15000], tokuteishisetsu: [9000, 15000], kaigo: [6000, 12000] },
        },
        korei: {
          '2割': { jitaku: [10000, 16000], gh: [6000, 10000], tokuteishisetsu: [6000, 10000], kaigo: [4000, 8000] },
          '3割': { jitaku: [15000, 24000], gh: [9000, 15000], tokuteishisetsu: [9000, 15000], kaigo: [6000, 12000] },
        },
        ippan: {
          '1割': { jitaku: [5000, 8000], gh: [3000, 5000], tokuteishisetsu: [3000, 5000], kaigo: [2000, 4000] },
          '2割': { jitaku: [10000, 16000], gh: [6000, 10000], tokuteishisetsu: [6000, 10000], kaigo: [4000, 8000] },
          '3割': { jitaku: [15000, 24000], gh: [9000, 15000], tokuteishisetsu: [9000, 15000], kaigo: [6000, 12000] },
        },
        seikatsu: { '0割': { jitaku: [0, 0], gh: [0, 0], tokuteishisetsu: [0, 0], kaigo: [0, 0] } },
      };
      const contentAdd = { basic: [0, 0], psych: [1500, 3000], treat: [2000, 5000], capd: [5000, 10000] };
      let step2shown = false,
        step3shown = false,
        step4shown = false,
        calcshown = false;
      const getSelected = (name) => document.querySelector(`input[name="${name}"]:checked`)?.value;
      function highlight(name) {
        document.querySelectorAll(`input[name="${name}"]`).forEach((inp) => {
          const btn = inp.closest('label')?.querySelector('.fee-btn');
          if (!btn) return;
          if (inp.checked) {
            btn.classList.add('border-primary', 'bg-blue-50');
            btn.classList.remove('border-gray-200');
          } else {
            btn.classList.remove('border-primary', 'bg-blue-50');
            btn.classList.add('border-gray-200');
          }
        });
      }
      function updateSteps() {
        const ins = getSelected('insurance'),
          ratio = getSelected('ratio'),
          place = getSelected('place'),
          content = getSelected('content');
        if (ins && !step2shown) {
          if (ins === 'seikatsu') {
            document.getElementById('step3-wrap').style.display = 'block';
            step3shown = true;
          } else {
            document.getElementById('step2-wrap').style.display = 'block';
            step2shown = true;
          }
        }
        if ((ratio || ins === 'seikatsu') && !step3shown) {
          document.getElementById('step3-wrap').style.display = 'block';
          step3shown = true;
        }
        if (place && !step4shown) {
          document.getElementById('step4-wrap').style.display = 'block';
          step4shown = true;
        }
        if (content && !calcshown) {
          document.getElementById('calc-btn-wrap').style.display = 'block';
          calcshown = true;
        }
      }
      document.querySelectorAll('input[type="radio"]').forEach((inp) => {
        inp.addEventListener('change', function () {
          highlight(this.name);
          updateSteps();
          document.getElementById('fee-result').classList.add('hidden');
        });
      });
      document.getElementById('fee-calc-btn')?.addEventListener('click', function () {
        const ins = getSelected('insurance'),
          place = getSelected('place') || 'jitaku',
          content = getSelected('content') || 'basic';
        let min, max;
        if (ins === 'seikatsu') {
          min = max = 0;
        } else {
          const ratio = getSelected('ratio') || '3割';
          const base = (table[ins] && table[ins][ratio] && table[ins][ratio][place]) || [5000, 8000];
          const add = contentAdd[content] || [0, 0];
          min = base[0] + add[0];
          max = base[1] + add[1];
        }
        const resultEl = document.getElementById('fee-result'),
          amountEl = document.getElementById('fee-amount');
        amountEl.textContent =
          min === 0 && max === 0 ? '0円（全額公費）' : `約 ${min.toLocaleString()}〜${max.toLocaleString()}円`;
        resultEl.classList.remove('hidden');
        // 内訳パネルを閉じた状態にリセット
        const breakdown = document.getElementById('fee-breakdown');
        const breakdownBtn = document.getElementById('fee-breakdown-btn');
        const breakdownIcon = document.getElementById('fee-breakdown-icon');
        if (breakdown && !breakdown.classList.contains('hidden')) {
          breakdown.classList.add('hidden');
          breakdownBtn?.setAttribute('aria-expanded', 'false');
          breakdownIcon?.classList.remove('rotate-180');
        }
        resultEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
      });

      // 費用内訳の折りたたみ
      document.getElementById('fee-breakdown-btn')?.addEventListener('click', function () {
        const breakdown = document.getElementById('fee-breakdown');
        const icon = document.getElementById('fee-breakdown-icon');
        const isOpen = this.getAttribute('aria-expanded') === 'true';
        if (isOpen) {
          breakdown?.classList.add('hidden');
          this.setAttribute('aria-expanded', 'false');
          icon?.classList.remove('rotate-180');
        } else {
          breakdown?.classList.remove('hidden');
          this.setAttribute('aria-expanded', 'true');
          icon?.classList.add('rotate-180');
        }
      });
    })();
  </script>

  <!-- 費用の流れ -->
  <Content
    tagline="費用の流れ"
    title="訪問診療費用の支払い方法"
    isReversed
    classes={{
      headline: {
        ...clinicalSectionHeadline,
        container: twMerge('max-w-xl sm:mx-auto lg:max-w-2xl text-left sm:text-center', clinicalSectionHeadline.container),
      },
    }}
    items={[
      {
        title: '毎月の請求書でお支払い',
        description: '当月の訪問診療費は翌月初旬に請求書をお届けします。銀行振込またはご来院でのお支払いが可能です。',
      },
      {
        title: '処方箋は保険薬局でお受け取り',
        description:
          '処方薬は保険薬局でお受け取りください。調剤費は別途薬局にお支払いいただきます。往診時に持参することも可能です。',
      },
      {
        title: '急変時の往診費用',
        description:
          '緊急往診（臨時往診）は定期訪問とは別に費用が発生する場合があります。夜間・休日加算が加わることがあります。',
      },
      {
        title: '費用の不明点はご相談ください',
        description: '費用についてのご不明点・ご不安はお電話（06-4301-7871）またはお問い合わせフォームでいつでもご相談いただけます。',
      },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        費用についてのご不明点はお気軽に
      </h3>
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- FAQ -->
  <FAQs
    id="faq"
    title="費用・保険に関するよくある質問"
    tagline="FAQ"
