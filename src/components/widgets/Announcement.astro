---
const NEW_BLOG_PATH = '/blog';
const ANNOUNCEMENT_TEXT = '院長コラム・お知らせ・スタッフブログを新HPで発信中';
---

<!--
  全ページ上部バー
  役割：新HPブログ（お知らせ・院長コラム）への導線
  表示：PC/タブレット以上（md:flex）。モバイルでは非表示（帯域節約）。
-->
<div
  class="hidden md:flex items-center justify-center gap-2 overflow-hidden px-4 py-2 text-sm
         bg-blue-700 text-white"
  role="banner"
  aria-label="お知らせ・ブログのご案内"
>
  <span
    class="inline-block bg-white/20 text-white font-semibold text-xs px-2 py-0.5 rounded shrink-0"
  >
    お知らせ
  </span>

  <span class="truncate">
    {ANNOUNCEMENT_TEXT}
  </span>

  <a
    href={NEW_BLOG_PATH}
    class="shrink-0 underline underline-offset-2 font-bold hover:text-blue-100 transition-colors whitespace-nowrap"
    aria-label="お知らせ・ブログを読む"
  >
    ブログを読む&nbsp;»
  </a>
</div>
