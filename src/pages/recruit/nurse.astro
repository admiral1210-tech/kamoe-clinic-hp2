---
import { SITE } from 'astrowind:config';
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import RecruitSection from '~/components/recruit/RecruitSection.astro';
import { Icon } from 'astro-icon/components';
import {
  clinicalHeroSubtitleClass,
  clinicalHeroTaglineClass,
  clinicalHeroTitleClass,
} from '~/constants/clinical-page-ui';
import { CLINIC_CONTACT } from '~/data/clinic-contact';
import {
  recruitNurseFulltime,
  recruitJobPostingNurseJsonLd,
} from '~/data/recruit';
import {
  nurseJobDetails,
  nurseDailyFlow,
  nurseWorkStyle,
  nurseOnboarding,
  nurseStaffMessage,
} from '~/data/recruit-nurse';
import { serializeJsonLdForScript } from '~/utils/json-ld-script';

const metadata = {
  title: '看護師 募集要項｜かもめクリニック（大阪市・訪問診療）',
  description:
    '診療同行看護師（正社員）の詳細募集要項。月給30〜35万円・土日休み・残業ほぼなし。大阪市内の在宅診療クリニックで働きませんか。',
  ignoreTitleTemplate: true,
  openGraph: {
    type: 'website',
    images: [{ url: '~/assets/images/default.png', width: 1200, height: 628 }],
  },
};

const nf = recruitNurseFulltime;

const jobPostingLd = {
  ...recruitJobPostingNurseJsonLd,
  url: new URL('/recruit/nurse', SITE.site).href,
  baseSalary: {
    '@type': 'MonetaryAmount',
    currency: 'JPY',
    value: {
      '@type': 'QuantitativeValue',
      minValue: 300000,
      maxValue: 350000,
      unitText: 'MONTH',
    },
  },
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: new URL('/', SITE.site).href },
    { '@type': 'ListItem', position: 2, name: '採用情報', item: new URL('/recruit', SITE.site).href },
    { '@type': 'ListItem', position: 3, name: '看護師募集要項', item: new URL('/recruit/nurse', SITE.site).href },
  ],
};

const jobPostingJson = serializeJsonLdForScript(jobPostingLd);
const breadcrumbJson = serializeJsonLdForScript(breadcrumbLd);
---

<Layout metadata={metadata}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jobPostingJson} />
    <script type="application/ld+json" set:html={breadcrumbJson} />
  </Fragment>

  <!-- ============================================================
    Hero
  ================================================================ -->
  <Hero
    tagline="看護師（正社員）募集"
    taglineClass={clinicalHeroTaglineClass}
    titleClass={clinicalHeroTitleClass}
    subtitleClass={`${clinicalHeroSubtitleClass} !mb-0`}
    sectionPaddingClass="pt-6 md:pt-10"
  >
    <Fragment slot="title">
      あなたの看護を、<br />
      <span class="text-accent highlight">患者さまの自宅で</span>発揮しませんか
    </Fragment>
    <Fragment slot="subtitle">
      診療同行看護師として、医師とペアで大阪市内を巡回します。<br class="hidden sm:inline" />
      残業ほぼなし・土日休み・月給30〜35万円。
    </Fragment>
    <Fragment slot="actions">
      <a
        href={CLINIC_CONTACT.telHref}
        class="btn btn-primary"
      >
        <Icon name="tabler:phone" class="w-5 h-5 mr-1.5" aria-hidden="true" />
        電話で応募・相談する
      </a>
      <a
        href="/recruit"
        class="btn btn-secondary"
      >
        <Icon name="tabler:arrow-left" class="w-5 h-5 mr-1.5" aria-hidden="true" />
        採用情報トップへ戻る
      </a>
    </Fragment>
  </Hero>

  <!-- ============================================================
    仕事内容（3つの柱）
  ================================================================ -->
  <RecruitSection id="job-details" class="py-section-y bg-white">
    <div class="max-w-7xl mx-auto px-section-x">
      <div class="text-center mb-10 max-w-3xl mx-auto">
        <p class="text-xs font-semibold text-primary tracking-widest uppercase mb-1">Job Details</p>
        <h2 class="text-2xl md:text-3xl font-bold text-heading">仕事内容 — 3つの柱</h2>
        <p class="mt-3 text-sm md:text-base text-muted leading-relaxed">
          「訪問看護」ではありません。<strong class="text-heading">常に医師とともに行動する「診療同行看護師」</strong>として、患者さまの生活を支えます。
        </p>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {nurseJobDetails.map((item) => (
          <div
            class:list={[
              'rounded-card border overflow-hidden flex flex-col',
              item.highlight
                ? 'border-primary/40 shadow-md'
                : 'border-gray-200 shadow-sm',
            ]}
          >
            <div class:list={['px-5 py-4 flex items-center gap-3', item.highlight ? 'bg-primary' : 'bg-primary/10']}>
              <span
                class:list={[
                  'text-2xl font-black tracking-tighter',
                  item.highlight ? 'text-white/60' : 'text-primary/40',
                ]}
              >
                {item.number}
              </span>
              <Icon
                name={item.icon}
                class:list={['w-6 h-6 shrink-0', item.highlight ? 'text-white' : 'text-primary']}
                aria-hidden="true"
              />
              <h3
                class:list={[
                  'font-bold text-sm leading-snug m-0',
                  item.highlight ? 'text-white' : 'text-heading',
                ]}
              >
                {item.title}
              </h3>
            </div>
            <div class="p-5 flex-1 bg-white">
              <p class="text-sm text-default leading-relaxed">{item.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </RecruitSection>

  <!-- ============================================================
    1日の流れ
  ================================================================ -->
  <RecruitSection id="daily-flow" class="py-section-y">
    <div class="max-w-3xl mx-auto px-section-x">
      <div class="text-center mb-10">
        <p class="text-xs font-semibold text-primary tracking-widest uppercase mb-1">Daily Flow</p>
        <h2 class="text-2xl md:text-3xl font-bold text-heading">1日の流れ</h2>
        <p class="mt-3 text-sm md:text-base text-muted leading-relaxed">
          規則正しいスケジュールで、プライベートとの両立が可能です。
        </p>
      </div>
      <ol class="relative border-l-2 border-primary/25 pl-8 space-y-8" aria-label="1日の業務タイムライン">
        {nurseDailyFlow.map((item, idx) => (
          <li class="relative">
            <span
              class="absolute -left-[2.35rem] top-0.5 flex h-7 w-7 items-center justify-center rounded-full bg-primary text-white text-xs font-bold"
              aria-hidden="true"
            >
              {idx + 1}
            </span>
            <div class="flex items-baseline gap-3">
              <time
                class="shrink-0 text-sm font-bold text-primary tabular-nums"
                datetime={item.time}
              >
                {item.time}
              </time>
              <h3 class="text-base font-bold text-heading m-0">{item.label}</h3>
            </div>
            <p class="mt-1 text-sm text-muted leading-relaxed">{item.desc}</p>
          </li>
        ))}
      </ol>
    </div>
  </RecruitSection>

  <!-- ============================================================
    働き方の魅力
  ================================================================ -->
  <RecruitSection id="work-style" class="py-section-y bg-white">
    <div class="max-w-7xl mx-auto px-section-x">
      <div class="text-center mb-10 max-w-3xl mx-auto">
        <p class="text-xs font-semibold text-primary tracking-widest uppercase mb-1">Work Style</p>
        <h2 class="text-2xl md:text-3xl font-bold text-heading">働き方の魅力</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {nurseWorkStyle.map((item) => (
          <div class="rounded-card border border-gray-200 bg-primary/5 p-6 flex flex-col items-center text-center shadow-sm">
            <div class="flex h-14 w-14 items-center justify-center rounded-full bg-primary/10 mb-4">
              <Icon name={item.icon} class="w-7 h-7 text-primary" aria-hidden="true" />
            </div>
            <h3 class="text-base font-bold text-heading mb-2">{item.title}</h3>
            <p class="text-sm text-muted leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </RecruitSection>

  <!-- ============================================================
    入職後サポート体制
  ================================================================ -->
  <RecruitSection id="onboarding" class="py-section-y">
    <div class="max-w-3xl mx-auto px-section-x">
      <div class="text-center mb-10">
        <p class="text-xs font-semibold text-primary tracking-widest uppercase mb-1">Onboarding</p>
        <h2 class="text-2xl md:text-3xl font-bold text-heading">入職後サポート体制</h2>
        <p class="mt-3 text-sm md:text-base text-muted leading-relaxed">
          訪問診療が初めてでも安心。丁寧なサポートで現場に慣れていただけます。
        </p>
      </div>
      <ol class="space-y-5" aria-label="入職後のサポートステップ">
        {nurseOnboarding.map((item) => (
          <li class="flex gap-4 items-start rounded-card border border-gray-200 bg-white p-5 shadow-sm">
            <span
              class="shrink-0 flex h-9 w-9 items-center justify-center rounded-full bg-primary text-white text-sm font-bold"
              aria-label={`ステップ ${item.step}`}
            >
              {item.step}
            </span>
            <div>
              <h3 class="text-base font-bold text-heading mb-1">{item.title}</h3>
              <p class="text-sm text-muted leading-relaxed">{item.desc}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </RecruitSection>

  <!-- ============================================================
    スタッフからのメッセージ
    ※ 患者の声ではなくスタッフの声のため医療法上掲載可
  ================================================================ -->
  <RecruitSection id="staff-voice" class="py-section-y bg-white">
    <div class="max-w-3xl mx-auto px-section-x">
      <div class="text-center mb-10">
        <p class="text-xs font-semibold text-primary tracking-widest uppercase mb-1">Staff Voice</p>
        <h2 class="text-2xl md:text-3xl font-bold text-heading">スタッフからのメッセージ</h2>
      </div>
      <figure class="rounded-card border border-primary/25 bg-primary/5 p-6 sm:p-8">
        <blockquote>
          <Icon name="tabler:quote" class="w-8 h-8 text-primary/30 mb-3" aria-hidden="true" />
          <p class="text-base text-default leading-relaxed italic">{nurseStaffMessage.message}</p>
        </blockquote>
        <figcaption class="mt-5 flex items-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-full bg-primary/20">
            <Icon name="tabler:user" class="w-5 h-5 text-primary" aria-hidden="true" />
          </div>
          <div>
            <p class="text-sm font-bold text-heading">{nurseStaffMessage.name}</p>
            <p class="text-xs text-muted">{nurseStaffMessage.role}</p>
          </div>
        </figcaption>
      </figure>
    </div>
  </RecruitSection>

  <!-- ============================================================
    詳細募集要項
  ================================================================ -->
  <RecruitSection id="requirements" class="py-section-y">
    <div class="max-w-4xl mx-auto px-section-x">
      <div class="text-center mb-10">
        <p class="text-xs font-semibold text-primary tracking-widest uppercase mb-1">Requirements</p>
        <h2 class="text-2xl md:text-3xl font-bold text-heading">詳細募集要項</h2>
      </div>

      <div class="rounded-card border-2 border-primary/40 overflow-hidden bg-white shadow-sm">
        <div class="bg-primary px-5 py-4 flex items-center gap-3">
          <Icon name="tabler:file-text" class="w-6 h-6 text-white shrink-0" aria-hidden="true" />
          <h3 class="text-white font-bold text-base sm:text-lg m-0">{nf.title}</h3>
        </div>

        <div class="p-5 sm:p-6">
          <!-- 概要グリッド -->
          <section
            class="mb-6 rounded-xl border border-primary/25 bg-gradient-to-b from-primary/[0.07] to-transparent px-4 py-4"
            aria-labelledby="nurse-keyfacts-heading"
          >
            <h4
              id="nurse-keyfacts-heading"
              class="text-xs font-bold text-primary tracking-wide uppercase mb-3"
            >
              {nf.keyFactsHeading}
            </h4>
            <dl class="grid grid-cols-1 gap-2.5 text-sm sm:grid-cols-2 sm:gap-3">
              {nf.keyFacts.map((row) => (
                <div class="rounded-lg border border-gray-200/90 bg-white/95 px-3 py-2.5 shadow-sm">
                  <dt class="mb-1 text-[0.7rem] font-semibold text-muted sm:text-xs">
                    {row.label}
                  </dt>
                  <dd class="font-medium leading-snug text-heading" set:html={row.valueHtml} />
                </div>
              ))}
            </dl>
          </section>

          <!-- イントロ文 -->
          {nf.introHtml.map((html) => (
            <p class="text-sm text-default mb-4 last:mb-0 leading-relaxed" set:html={html} />
          ))}

          <!-- 詳細2カラム -->
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 text-sm mt-6">
            <div class="space-y-3 min-w-0">
              {nf.leftColumn.map((row, i) => (
                <div
                  class:list={[
                    'flex gap-3 items-start min-w-0',
                    i < nf.leftColumn.length - 1 ? 'border-b border-gray-100 pb-3' : '',
                  ]}
                >
                  <span class="font-semibold text-muted w-24 shrink-0">{row.label}</span>
                  <span class="min-w-0 flex-1 text-default" set:html={row.valueHtml} />
                </div>
              ))}
            </div>
            <div class="space-y-3 min-w-0">
              {nf.rightColumn.map((row, i) => (
                <div
                  class:list={[
                    'flex gap-3 items-start min-w-0',
                    i < nf.rightColumn.length - 1 ? 'border-b border-gray-100 pb-3' : '',
                  ]}
                >
                  <span class="font-semibold text-muted w-24 shrink-0">{row.label}</span>
                  <span class="min-w-0 flex-1 text-default" set:html={row.valueHtml} />
                </div>
              ))}
            </div>
          </div>

          <!-- 勤務先情報 -->
          <div class="mt-6 rounded-xl border border-gray-200 bg-gray-50 p-4 text-sm space-y-1.5">
            <p class="font-semibold text-heading">勤務先</p>
            <p class="text-default">医療法人かもめ会 かもめクリニック</p>
            <p class="text-muted">{CLINIC_CONTACT.postalCode} {CLINIC_CONTACT.addressLine1} {CLINIC_CONTACT.addressLine2}</p>
            <p class="text-muted">最寄駅：大阪市営地下鉄中央線 朝潮橋駅から徒歩3分</p>
          </div>

          <!-- 求める人物像 -->
          <div class="mt-6 bg-blue-50 rounded-xl p-4">
            <p class="text-sm font-semibold text-primary mb-2">{nf.desiredProfile.heading}</p>
            <ul class="text-sm text-default space-y-1">
              {nf.desiredProfile.items.map((text, idx) => {
                const isLast = idx === nf.desiredProfile.items.length - 1;
                const emphasized = nf.desiredProfile.emphasizedLast && isLast;
                return (
                  <li class:list={[emphasized ? 'text-primary font-medium' : '']}>
                    ・{text}
                  </li>
                );
              })}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </RecruitSection>

  <!-- ============================================================
    応募CTA
  ================================================================ -->
  <RecruitSection id="apply" class="py-section-y bg-primary">
    <div class="max-w-3xl mx-auto px-section-x text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">
        一緒に訪問診療を支えませんか
      </h2>
      <p class="text-white/85 text-sm md:text-base leading-relaxed mb-8">
        ご質問・応募書類の送付はお気軽にどうぞ。<br />
        受付：{CLINIC_CONTACT.hoursPrimary}　TEL：{CLINIC_CONTACT.telDisplay}
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={CLINIC_CONTACT.telHref}
          class="inline-flex items-center justify-center gap-2 rounded-pill bg-white text-primary font-bold px-7 py-3.5 text-base hover:bg-white/90 transition-colors focus-visible:ring-2 focus-visible:ring-white"
        >
          <Icon name="tabler:phone" class="w-5 h-5 shrink-0" aria-hidden="true" />
          {CLINIC_CONTACT.telDisplay}
        </a>
      </div>

      <div class="mt-8 rounded-card bg-white/10 p-5 text-sm text-white/85 text-left space-y-1">
        <p class="font-semibold text-white mb-2">応募書類のご案内</p>
        <p>・履歴書（写真貼付）</p>
        <p>・職務経歴書（お持ちの場合）</p>
        <p class="text-white/65 text-xs mt-2">
          ※ お電話いただいた後、郵送またはメールにてお送りください。書類到着後1週間以内に結果をご連絡します。
        </p>
      </div>
    </div>
  </RecruitSection>
</Layout>
