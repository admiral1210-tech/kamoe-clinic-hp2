---
/**
 * ユーザー向けブログ一覧の唯一の正（canonical）はこの /blog ページ。
 * 旧 Astrowind テンプレの [...blog]/[...page] 一覧は廃止済み。
 */
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import { Icon } from 'astro-icon/components';
import { fetchPostSummaries, blogListRobots } from '~/utils/blog';
import { getCanonical } from '~/utils/permalinks';
import OldBlogNotice from '~/components/blog/OldBlogNotice.astro';
import BlogPostCard from '~/components/blog/BlogPostCard.astro';
import { serializeJsonLdForScript } from '~/utils/json-ld-script';

const posts = await fetchPostSummaries();

const heroImageUrl = String(getCanonical('/images/top/slider02.jpg'));

const metadata = {
  title: 'お知らせ・ブログ｜かもめクリニック（大阪市）',
  description:
    'かもめクリニックのお知らせ・ブログ記事一覧。診療体制・休診・採用・地域連携などの最新情報を掲載しています。',
  ignoreTitleTemplate: true,
  robots: {
    index: blogListRobots?.index,
    follow: blogListRobots?.follow,
  },
  openGraph: {
    type: 'website',
    images: [{ url: heroImageUrl, width: 1400, height: 500 }],
  },
};

const jsonLdBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'トップページ', item: String(getCanonical('/')) },
    { '@type': 'ListItem', position: 2, name: 'お知らせ・ブログ', item: String(getCanonical('/blog')) },
  ],
};
---

<Layout metadata={metadata}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={serializeJsonLdForScript(jsonLdBreadcrumb)} />
  </Fragment>

  <Hero tagline="お知らせ・ブログ">
    <Fragment slot="title">お知らせ・ブログ</Fragment>
    <Fragment slot="subtitle">
      院長コラム・スタッフ記事・診療体制のお知らせなど、かもめクリニックの最新情報をお届けします。
    </Fragment>
  </Hero>

  <OldBlogNotice variant="note" />

  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      {
        posts.length === 0 ? (
          <div class="text-center py-16">
            <Icon
              name="tabler:news-off"
              class="w-12 h-12 mx-auto text-gray-300 mb-4"
              aria-hidden="true"
            />
            <p class="text-gray-500 text-lg m-0">現在、新規記事を作成中です。</p>
            <OldBlogNotice variant="empty" />
          </div>
        ) : (
          <ul class="flex flex-col gap-6 list-none p-0 m-0">
            {posts.map((post) => (
              <BlogPostCard post={post} />
            ))}
          </ul>
        )
      }
    </div>
  </section>
</Layout>
