---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import { Icon } from 'astro-icon/components';
import { OSAKA_CITY_WARDS } from '~/data/osaka-wards';
import {
  clinicalHeroSubtitleClass,
  clinicalHeroTaglineClass,
  clinicalHeroTitleClass,
  ctaHeroPrimaryClass,
} from '~/constants/clinical-page-ui';
import { KAMOME_BRANCH_COUNT } from '~/data/branches';
import { serializeJsonLdForScript } from '~/utils/json-ld-script';

const metadata = {
  title: '訪問診療の対応エリア（大阪市）｜かもめクリニック',
  description: `大阪市24区全域で訪問診療・緊急往診に対応。${KAMOME_BRANCH_COUNT}院体制で市内をカバーします。区ごとの案内ページ・地域医療連携部（06-4301-7883）をご利用ください。`,
  ignoreTitleTemplate: true,
  openGraph: {
    type: 'website',
    images: [{ url: 'https://kamome-clinic.net/images/top/slider02.jpg', width: 1400, height: 500 }],
  },
};

const jsonLdBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'トップページ', item: 'https://kamome-clinic.net/' },
    { '@type': 'ListItem', position: 2, name: '大阪市の対応エリア', item: 'https://kamome-clinic.net/area-osaka' },
  ],
};

const jsonLdWebPage = {
  '@context': 'https://schema.org',
  '@type': 'MedicalWebPage',
  '@id': 'https://kamome-clinic.net/area-osaka',
  name: '訪問診療の対応エリア（大阪市）｜かもめクリニック',
  url: 'https://kamome-clinic.net/area-osaka',
  description: `かもめクリニックは大阪市24区全域で訪問診療・緊急往診に対応しています。市内${KAMOME_BRANCH_COUNT}院体制でカバーし、詳細は地域医療連携部（06-4301-7883）までお問い合わせください。`,
  isPartOf: { '@type': 'WebSite', '@id': 'https://kamome-clinic.net/#website' },
  about: { '@type': 'MedicalClinic', '@id': 'https://kamome-clinic.net/#clinic', name: 'かもめクリニック' },
};
---

<Layout metadata={metadata}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={serializeJsonLdForScript(jsonLdBreadcrumb)} />
    <script type="application/ld+json" set:html={serializeJsonLdForScript(jsonLdWebPage)} />
  </Fragment>

  <Hero
    tagline="訪問診療エリア"
    taglineClass={clinicalHeroTaglineClass}
    titleClass={clinicalHeroTitleClass}
    subtitleClass={clinicalHeroSubtitleClass}
  >
    <Fragment slot="title">大阪市の対応エリア</Fragment>
    <Fragment slot="subtitle">
      <strong>訪問診療</strong>および<strong>緊急往診</strong>の対象エリアは、大阪市の<strong>24区すべて</strong>です。<strong
        >{KAMOME_BRANCH_COUNT}院体制</strong
      >で市内全域をカバーしています。区ごとに紹介ページのある区はリンクからご覧ください。
    </Fragment>
  </Hero>

  <section class="py-10 md:py-14 bg-gray-50 dark:bg-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="text-center text-xs text-gray-500 dark:text-gray-400 mb-3">大阪市24区（市の区並び順）</p>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-2 mb-8">
        {
          OSAKA_CITY_WARDS.map(({ name, slug }) =>
            slug ? (
              <a
                href={`/area/${slug}`}
                class="bg-white dark:bg-slate-900 border border-blue-200 dark:border-slate-700 text-gray-800 dark:text-gray-200 hover:border-primary px-3 py-2.5 rounded-xl text-sm font-medium transition-colors inline-flex items-center justify-center gap-1 text-center"
              >
                {name}
                <Icon name="tabler:arrow-right" class="w-3.5 h-3.5 shrink-0 text-primary" />
              </a>
            ) : (
              <span class="bg-white/80 dark:bg-slate-900/80 border border-dashed border-blue-200 dark:border-slate-600 text-gray-700 dark:text-gray-300 px-3 py-2.5 rounded-xl text-sm font-medium inline-flex flex-col sm:flex-row items-center justify-center gap-0.5 text-center leading-tight">
                <span>{name}</span>
                <span class="text-xs text-gray-500 dark:text-gray-500">（詳細はお電話）</span>
              </span>
            )
          )
        }
      </div>

      <div class="max-w-3xl mx-auto bg-white dark:bg-slate-900 rounded-2xl border border-blue-100 dark:border-slate-700 p-6 text-center">
        <p class="text-sm text-gray-600 dark:text-gray-400 mb-4 max-w-prose mx-auto">
          大阪市外のご相談や、担当院の調整なども地域医療連携部がお受けします。まずはお気軽にどうぞ。
        </p>
        <a href="tel:0643017883" class:list={[ctaHeroPrimaryClass, 'inline-flex gap-2']}>
          <Icon name="tabler:phone" class="w-4 h-4 shrink-0" /> エリア・連携のご相談 06-4301-7883
        </a>
        <p class="mt-4">
          <a href="/houmon-shinryo" class="text-primary text-sm font-bold hover:underline">訪問診療とは・ご利用の流れ</a>
          <span class="text-gray-300 dark:text-gray-600 mx-2">|</span>
          <a href="/about#access" class="text-primary text-sm font-bold hover:underline">各院のアクセス</a>
        </p>
      </div>
    </div>
  </section>
</Layout>
