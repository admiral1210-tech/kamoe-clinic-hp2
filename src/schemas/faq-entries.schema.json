{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "faq-entries.schema.json",
  "title": "FAQ Entries",
  "description": "かもめクリニック FAQエントリーのスキーマ。プレースホルダー（{{TEL}}等）はビルド時に置換される。",
  "type": "object",
  "required": ["entries"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["question", "answerPlain"],
        "additionalProperties": false,
        "properties": {
          "question": {
            "type": "string",
            "minLength": 1,
            "description": "質問文（プレースホルダー使用不可）"
          },
          "answerPlain": {
            "type": "string",
            "minLength": 1,
            "description": "回答のプレーンテキスト版。プレースホルダー（{{TEL}}, {{BRANCH_COUNT}}等）使用可。"
          },
          "answerHtml": {
            "type": "string",
            "minLength": 1,
            "description": "回答のHTML版（省略時はanswerPlainを使用）。プレースホルダー（{{TEL}}, {{TEL_HREF}}等）使用可。"
          },
          "trailingSnippet": {
            "type": "string",
            "enum": ["phoneFormConsult", "costPageAndPhone"],
            "description": "末尾に追加する定型スニペット。phoneFormConsult=電話+フォームリンク、costPageAndPhone=費用ページ+電話。"
          }
        }
      }
    }
  }
}
