---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/widgets/Header.astro';
import Footer from '~/components/widgets/Footer.astro';
import Announcement from '~/components/widgets/Announcement.astro';
import { Icon } from 'astro-icon/components';

import { headerData, footerData } from '~/navigation';
import { CLINIC_CONTACT } from '~/data/clinic-contact';
import { getPermalink } from '~/utils/permalinks';

import type { MetaData } from '~/types';

export interface Props {
  metadata?: MetaData;
}

const { metadata } = Astro.props;

const contactFormHref = getPermalink('/renkei#renkei-contact-detail');
---

<Layout metadata={metadata}>
  <!-- headスロットをLayoutに転送（JSON-LD・preloadなど） -->
  <slot name="head" slot="head" />
  <slot name="announcement">
    <Announcement />
  </slot>
  <slot name="header">
    <Header {...headerData} isSticky />
  </slot>
  <main>
    <slot />
  </main>
  <!-- 全ページ共通：医療情報免責バナー -->
  <aside aria-label="医療情報に関するご案内" class="bg-gray-100 dark:bg-slate-800 border-t border-gray-200 dark:border-slate-700 py-3 px-4">
    <p class="max-w-5xl mx-auto text-xs text-gray-500 dark:text-gray-400 leading-relaxed text-center">
      当サイトの情報は一般的な医療知識の提供を目的としており、個別の診断・治療を保証するものではありません。
      症状や治療方針についてはかかりつけ医または担当医師にご相談ください。
    </p>
  </aside>
  <slot name="footer">
    <Footer {...footerData} />
  </slot>

  <nav
    class="floating-cta"
    id="floating-cta"
    aria-label="固定表示の連絡先（電話・問い合わせフォーム）"
  >
    <a href={CLINIC_CONTACT.telHref} class="floating-cta-tel">
      <Icon name="tabler:phone" class="w-4 h-4" aria-hidden="true" /> {CLINIC_CONTACT.telDisplay}
    </a>
    <a href={contactFormHref} class="floating-cta-form">
      <Icon name="tabler:clipboard-list" class="w-4 h-4" aria-hidden="true" /> 問い合わせフォーム
    </a>
  </nav>
</Layout>
