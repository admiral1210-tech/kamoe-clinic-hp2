---
import CallToAction from '~/components/widgets/CallToAction.astro';
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: '診療内容｜内科・精神科・小児科・ターミナルケア｜かもめクリニック',
  description:
    'かもめクリニックの診療内容。内科・精神科・小児科の訪問診療、ターミナルケア、24時間365日の緊急往診に対応。精神科専門医3名常勤は大阪市内の訪問診療クリニックとして唯一。',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="診療内容"
    title="内科・精神科・小児科の<br/>訪問診療に対応"
    subtitle="ご自宅・施設へ医師が定期的に伺い、診察・処方・各種検査を行う<strong>訪問診療専門クリニック</strong>です。内科・精神科・小児科に対応し、<strong>24時間365日の緊急往診</strong>で在宅生活をしっかり支えます。"
    actions={[
      { variant: 'primary', text: 'お電話でのご相談', href: 'tel:0643017871', icon: 'tabler:phone' },
      {
        variant: 'line',
        text: 'LINEで無料相談',
        href: 'https://line.me/R/ti/p/%40512ysmzx',
        icon: 'tabler:brand-line',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1576091160550-2173dba999ef?auto=format&fit=crop&w=1740&q=80',
      alt: '訪問診療イメージ',
    }}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="主な診療内容"
    subtitle="通院が困難な方のご自宅・施設へ、専門の医師が定期的に伺います。"
    columns={3}
    items={[
      {
        title: '内科（一般訪問診療）',
        description:
          '高血圧・糖尿病・心不全・COPD・慢性腎臓病などの生活習慣病や慢性疾患の管理。点滴・褥瘡処置・カテーテル管理なども対応します。',
        icon: 'tabler:stethoscope',
      },
      {
        title: '精神科（大阪市内唯一）',
        description:
          '精神科専門医3名が常勤する、大阪市内唯一の体制です。うつ病・統合失調症・認知症・依存症・発達障がいなど、幅広い精神科疾患に対応します。',
        icon: 'tabler:brain',
      },
      {
        title: '小児科（医療的ケア児）',
        description:
          '医療的ケアが必要なお子さまや、障がいのある子どもの訪問診療に対応。学校・保育所・自宅など生活の場へ伺います。',
        icon: 'tabler:baby-carriage',
      },
      {
        title: 'ターミナルケア（在宅看取り）',
        description:
          'グループ全体で年間約100件の在宅看取りを実施。ご本人の想いを最優先に、ご家族への丁寧なサポートと多職種連携で最期まで支えます。',
        icon: 'tabler:heart-handshake',
      },
      {
        title: '緊急往診（24時間365日）',
        description:
          '機能強化型在宅療養支援診療所（在支診1）として、夜間・休日・年末年始を問わず急変時に迅速対応。安心して任せられるかかりつけ医として寄り添います。',
        icon: 'tabler:ambulance',
      },
      {
        title: '施設・グループホーム対応',
        description:
          '対応施設50以上。有料老人ホーム・グループホーム・サービス付き高齢者向け住宅など、各種施設への定期訪問に対応しています。',
        icon: 'tabler:building-community',
      },
    ]}
  />

  <!-- Content Widget（精神科）-->

  <Content
    isReversed
    items={[
      {
        title: '精神科専門医3名常勤',
        description: '精神科専門医が3名常勤する、大阪市内唯一の体制です。',
        icon: 'tabler:certificate',
      },
      {
        title: 'うつ病・統合失調症・認知症・依存症',
        description: '精神科疾患を持つ方の在宅療養を、専門医が継続的にサポートします。',
        icon: 'tabler:brain',
      },
      {
        title: '薬剤調整・訪問看護との連携',
        description: '向精神薬の管理・調整から、訪問看護・ヘルパーとの多職種連携まで対応します。',
        icon: 'tabler:pill',
      },
      {
        title: '措置入院・精神科救急にも対応',
        description: '緊急時には精神科救急や入院調整のサポートも行います。',
        icon: 'tabler:urgent',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1559757175-0eb30cd8c063?auto=format&fit=crop&w=870&q=80',
      alt: '精神科訪問診療',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">精神科の訪問診療</h3>
      <p class="text-muted">精神科専門医3名が常勤する大阪市内唯一の体制で、精神疾患を抱える方の在宅療養を支えます。</p>
    </Fragment>
  </Content>

  <!-- Content Widget（ターミナルケア）-->

  <Content
    isAfterContent
    items={[
      {
        title: 'ご本人の想いを最優先に',
        description: '「自宅で最期を迎えたい」「住み慣れた場所にいたい」というご本人の意向を最も大切にします。',
        icon: 'tabler:heart',
      },
      {
        title: '年間約100件の在宅看取り実績',
        description: 'グループ全体で年間約100件の在宅看取りを実施。豊富な経験と体制で最期の時間を支えます。',
        icon: 'tabler:home-heart',
      },
      {
        title: 'ご家族へのサポート',
        description: '看取り後のグリーフケアも含め、ご家族が安心して送り出せるよう丁寧に寄り添います。',
        icon: 'tabler:users',
      },
      {
        title: '多職種・関係機関との連携',
        description: '訪問看護・ケアマネージャー・MSW・薬剤師など、関係各所と密に連携しながら支援します。',
        icon: 'tabler:network',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1582750433449-648ed127bb54?auto=format&fit=crop&w=774&q=80',
      alt: 'ターミナルケア・在宅看取り',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">ターミナルケア・在宅看取り</h3>
      <p class="text-muted">
        グループ全体で年間約100件の在宅看取りを実施。ご本人・ご家族への丁寧なケアと、関係各所との連携を大切にしています。
      </p>
    </Fragment>
  </Content>

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'お電話でのご相談',
        href: 'tel:06-4301-7871',
        icon: 'tabler:phone',
      },
      {
        variant: 'line',
        text: 'LINEで無料相談',
        href: 'https://line.me/R/ti/p/%40512ysmzx',
        icon: 'tabler:brand-line',
      },
    ]}
    title="まずはお気軽にご相談ください"
    subtitle="紹介状がなくてもご相談いただけます。受付：平日 9:00〜17:00 | 緊急往診は24時間365日対応"
  />
</Layout>
