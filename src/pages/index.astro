---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { Icon } from 'astro-icon/components';
import FaqAccordionList from '~/components/ui/FaqAccordionList.astro';
import {
  buildAggregateRating,
  buildNumberOfEmployees,
  getBranchFoundingDate,
  cumulativeStats,
  googleReview,
} from '~/data/clinic-meta';
import { CLINIC_GENERAL_FAQ, CLINIC_GENERAL_FAQ_PREVIEW_COUNT } from '~/data/faq-general';
import { OLD_BLOG_URL } from '~/data/site-policy';

const metadata = {
  title: 'かもめクリニック｜大阪市の訪問診療 内科・精神科・小児科｜2017年開院',
  description:
    '大阪市の機能強化型在宅療養支援診療所（在支診1）。2017年開院9年の実績。グループ患者数1,000名・年間診察1.2万件。精神科専門医3名常勤（大阪市内唯一）。内科・精神科・小児科対応。24時間365日緊急往診。健康保険・介護保険適用。',
  ignoreTitleTemplate: true,
  openGraph: {
    type: 'website',
    images: [{ url: 'https://www.kamome-clinic.net/images/top/slider02.jpg', width: 1400, height: 500 }],
  },
  twitter: { cardType: 'summary_large_image' },
};

// ===== JSON-LD: 組織情報（機能強化型在支診1・LINE・foundingDate）=====
const jsonLdClinic = {
  '@context': 'https://schema.org',
  '@id': 'https://kamome-clinic.net/#clinic',
  '@type': ['MedicalClinic', 'LocalBusiness'],
  name: 'かもめクリニック',
  alternateName: 'Kamome Clinic',
  url: 'https://kamome-clinic.net',
  logo: 'https://www.kamome-clinic.net/images/common/header/logo.png',
  image: 'https://www.kamome-clinic.net/images/common/header/logo.png',
  foundingDate: '2017',
  description:
    '大阪市の機能強化型在宅療養支援診療所（在支診1）。精神科専門医3名常勤（大阪市内唯一）。内科・精神科・小児科対応。グループ患者数1,000名・年間1.2万件の診察実績。年間看取り約100件・対応施設50以上。',
  telephone: '06-4301-7871',
  faxNumber: '06-4301-7872',
  email: 'kamome@kamome-clinic.net',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '夕凪2丁目16-9 icrossAMポートビル 4F-B',
    addressLocality: '大阪市港区',
    addressRegion: '大阪府',
    postalCode: '552-0004',
    addressCountry: 'JP',
  },
  geo: { '@type': 'GeoCoordinates', latitude: 34.6623, longitude: 135.4474 },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '09:00',
      closes: '17:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
      opens: '00:00',
      closes: '23:59',
      description: '緊急往診（24時間365日対応）',
    },
  ],
  medicalSpecialty: [
    'https://schema.org/InternalMedicine',
    'https://schema.org/Psychiatry',
    'https://schema.org/Pediatrics',
  ],
  availableService: [
    { '@type': 'MedicalTherapy', name: '訪問診療（月2回定期）' },
    { '@type': 'MedicalTherapy', name: '24時間緊急往診' },
    { '@type': 'MedicalTherapy', name: '精神科訪問診療（専門医3名常勤・大阪市内唯一）' },
    { '@type': 'MedicalTherapy', name: '医療ケア児訪問診療・NICU退院後支援' },
    { '@type': 'MedicalTherapy', name: '機能強化型在宅療養支援診療所（在支診1）としての24時間体制' },
    { '@type': 'MedicalTherapy', name: '在宅看取り・ターミナルケア（年間約100件実績）' },
  ],
  contactPoint: [
    {
      '@type': 'ContactPoint',
      telephone: '06-4301-7871',
      contactType: 'customer service',
      availableLanguage: 'Japanese',
      hoursAvailable: {
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
        opens: '09:00',
        closes: '17:00',
      },
    },
    {
      '@type': 'ContactPoint',
      telephone: '06-4301-7883',
      contactType: 'customer service',
      name: '地域医療連携部（医療・介護関係者専用）',
      availableLanguage: 'Japanese',
      hoursAvailable: {
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
        opens: '09:00',
        closes: '17:00',
      },
    },
  ],
  identifier: [
    { '@type': 'PropertyValue', propertyID: '保険医療機関コード', value: '0402898' },
    { '@type': 'PropertyValue', propertyID: '介護サービス事業者番号', value: '2710402898' },
  ],
  numberOfEmployees: buildNumberOfEmployees(),
  ...(buildAggregateRating() ? { aggregateRating: buildAggregateRating() } : {}),
  sameAs: [
    'https://line.me/R/ti/p/%40512ysmzx',
    'https://www.instagram.com/kamomeclinic/',
    'https://www.kamome-clinic.net',
    'https://kamome-clinic5.net/',
    'https://kamome-clinic7.net/',
  ],
  hasMap:
    'https://maps.google.com/maps?q=%E5%A4%A7%E9%98%AA%E5%B8%82%E6%B8%AF%E5%8C%BA%E5%A4%95%E5%87%AA2%E4%B8%81%E7%9B%AE16-9',
  privacyPolicy: 'https://kamome-clinic.net/privacy',
  priceRange: '保険適用（自己負担1〜3割）',
  areaServed: [
    '大阪市港区',
    '大阪市西淀川区',
    '大阪市住之江区',
    '大阪市西区',
    '大阪市大正区',
    '大阪市浪速区',
    '大阪市此花区',
    '大阪市淀川区',
  ],
};

// ===== JSON-LD: 各支院 LocalBusiness =====
const jsonLdBranches = [
  { name: 'かもめクリニック第2', street: '夕凪2丁目17-14', tel: '+81-6-6556-9571', fax: null, bid: 'branch2' as const },
  {
    name: 'かもめクリニック第3',
    street: '東住吉区駒川3丁目29-14',
    tel: '+81-6-6115-6045',
    fax: '+81-6-6115-6046',
    bid: 'branch3' as const,
  },
  { name: 'かもめクリニック第4', street: '西淀川区柏里1丁目16-15', tel: '+81-6-7506-9565', fax: null, bid: 'branch4' as const },
  { name: 'かもめクリニック第5', street: '住之江区北加賀屋2-12-6', tel: '+81-6-6115-7018', fax: null, bid: 'branch5' as const },
  {
    name: 'かもめクリニック第8',
    street: '住吉区千躰2-2-39 ホリビル3階',
    tel: '+81-6-6629-8852',
    fax: null,
    bid: 'branch8' as const,
  },
].map((b) => ({
  '@context': 'https://schema.org',
  '@id': `https://kamome-clinic.net/#${b.bid}`,
  '@type': 'MedicalClinic',
  name: b.name,
  parentOrganization: {
    '@type': 'MedicalClinic',
    '@id': 'https://kamome-clinic.net/#clinic',
    name: 'かもめクリニック',
  },
  address: {
    '@type': 'PostalAddress',
    streetAddress: b.street,
    addressLocality: '大阪市',
    addressRegion: '大阪府',
    addressCountry: 'JP',
  },
  telephone: b.tel,
  ...(b.fax ? { faxNumber: b.fax } : {}),
  ...(getBranchFoundingDate(b.bid) ? { foundingDate: getBranchFoundingDate(b.bid) } : {}),
}));

// ===== JSON-LD: 医師情報（Physician） =====
const jsonLdPhysicians = [
  {
    name: '木下 啓太',
    jobTitle: '院長',
    spec: ['https://schema.org/InternalMedicine'],
    cert: '日本内科学会認定医・腎臓学会専門医・透析医学会専門医',
  },
  {
    name: '石本 英之',
    jobTitle: '精神科専門医',
    spec: ['https://schema.org/Psychiatry'],
    cert: '精神保健指定医・医学博士・日本神経精神学会専門医',
  },
  {
    name: '菅近 優',
    jobTitle: '精神科専門医・指導医',
    spec: ['https://schema.org/Psychiatry'],
    cert: '精神保健指定医・医学博士・指導医',
  },
  { name: '西田 宜代', jobTitle: '精神科専門医', spec: ['https://schema.org/Psychiatry'], cert: '精神保健指定医' },
  { name: '河内 要', jobTitle: '第4院院長', spec: ['https://schema.org/Pediatrics'], cert: '小児科専門医' },
].map((d) => ({
  '@context': 'https://schema.org',
  '@type': 'Physician',
  name: d.name,
  jobTitle: d.jobTitle,
  medicalSpecialty: d.spec,
  description: d.cert,
  worksFor: { '@type': 'MedicalClinic', '@id': 'https://kamome-clinic.net/#clinic', name: 'かもめクリニック' },
  url: 'https://kamome-clinic.net/about#doctors',
}));

// ===== JSON-LD: WebSite（サイト検索ボックス対応） =====
const jsonLdWebSite = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': 'https://kamome-clinic.net/#website',
  name: 'かもめクリニック',
  url: 'https://kamome-clinic.net',
  publisher: { '@type': 'MedicalClinic', '@id': 'https://kamome-clinic.net/#clinic' },
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://kamome-clinic.net/faq',
    'query-input': 'required name=search_term_string',
  },
};

// ===== JSON-LD: BreadcrumbList =====
const jsonLdBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [{ '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://kamome-clinic.net/' }],
};

// ===== JSON-LD: Speakable（音声検索対応） =====
const jsonLdSpeakable = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': 'https://kamome-clinic.net/',
  name: 'かもめクリニック 訪問診療',
  datePublished: '2017-04-01',
  dateModified: '2026-03-30',
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['#about-houmon', '#features', '#faq-preview'],
  },
  url: 'https://kamome-clinic.net',
};
---

<Layout metadata={metadata}>
  <Fragment slot="head">
    <!-- ヒーロー画像（LCP要素）のpreload -->
    <link rel="preload" as="image" href="/images/hero-group.jpg" fetchpriority="high" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdClinic)} />
    {jsonLdBranches.map((b) => <script type="application/ld+json" set:html={JSON.stringify(b)} />)}
    {jsonLdPhysicians.map((p) => <script type="application/ld+json" set:html={JSON.stringify(p)} />)}
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdSpeakable)} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebSite)} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdBreadcrumb)} />
  </Fragment>

  <!-- ============================================================ Hero ================================================================ -->
  <Hero
    tagline="大阪市の訪問診療専門｜24時間365日・大阪市内5院体制"
    actions={[
      { variant: 'primary', text: 'お電話でのご相談', href: 'tel:0643017871', icon: 'tabler:phone' },
      {
        variant: 'line',
        text: 'LINEで無料相談',
        href: 'https://line.me/R/ti/p/%40512ysmzx',
        icon: 'tabler:brand-line',
      },
    ]}
  >
    <Fragment slot="image">
      <div class="w-full mt-8">
        <img
          src="/images/hero-group.jpg"
          alt="かもめクリニックのスタッフチーム"
          class="w-full rounded-2xl object-cover shadow-xl"
          width="1400"
          height="500"
          style="max-height: 480px; object-position: center top;"
        />
      </div>
    </Fragment>
    <Fragment slot="title">
      ご自宅・施設への<br />
      <span class="text-accent dark:text-white highlight">訪問診療</span>で<br />
      支えます
    </Fragment>
    <Fragment slot="subtitle">
      大阪市内でご自宅・施設へ医師が定期訪問し、診察・処方・検査を行う<strong>訪問診療専門クリニック</strong>です。<br
      /><br />
      内科・精神科・小児科に対応し、急な変化のときは<strong>24時間365日の緊急往診</strong>も承ります。
    </Fragment>
  </Hero>

  <!-- 在支診1 + 受付時間 ノート -->
  <!-- 受付・連絡先バー -->
  <section class="bg-blue-50 dark:bg-slate-800 border-b border-blue-100 dark:border-slate-700 not-prose">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-4">
      <!-- モバイル：縦並び / デスクトップ：横並び -->
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-center gap-3 sm:gap-8 text-center">
        <!-- 電話番号（大きく・タップで発信） -->
        <a href="tel:0643017871" class="flex items-center justify-center gap-2 group">
          <Icon name="tabler:phone" class="w-5 h-5 text-primary shrink-0" />
          <span class="text-2xl font-black text-primary tracking-wide group-hover:underline">06-4301-7871</span>
        </a>

        <!-- 区切り線（デスクトップのみ） -->
        <span class="hidden sm:block w-px h-8 bg-blue-200 dark:bg-slate-600"></span>

        <!-- 受付時間・緊急対応 -->
        <div
          class="flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-6 text-sm font-medium text-gray-700 dark:text-gray-300"
        >
          <span class="flex items-center justify-center gap-1.5">
            <Icon name="tabler:clock" class="w-4 h-4 text-primary shrink-0" />
            受付：<strong>平日・祝日 9:00〜17:00</strong>
          </span>
          <span class="flex items-center justify-center gap-1.5">
            <Icon name="tabler:ambulance" class="w-4 h-4 text-primary shrink-0" />
            緊急往診：<strong>24時間365日対応</strong>
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- ページ内目次（追従：ヘッダー高さ分ずらして重なりを防止） -->
  <nav
    class="sticky z-30 top-[4.5rem] md:top-[4.75rem] border-b border-gray-200/80 dark:border-slate-700 bg-white/90 dark:bg-slate-900/90 backdrop-blur-md not-prose shadow-sm"
    aria-label="このページの目次"
  >
    <div class="max-w-5xl mx-auto px-3 sm:px-6 pt-2 pb-1.5">
      <p
        class="text-center text-[10px] sm:text-xs font-semibold text-gray-500 dark:text-gray-400 tracking-wide mb-1.5"
      >
        このページの目次
      </p>
      <ul class="flex flex-wrap justify-center gap-x-1 gap-y-1 sm:gap-x-2 text-xs sm:text-sm">
        <li>
          <a
            href="#about-houmon"
            class="inline-flex items-center rounded-full px-2.5 py-1 sm:px-3 font-medium text-gray-700 dark:text-gray-200 hover:bg-blue-50 dark:hover:bg-slate-800 hover:text-primary transition-colors"
            >訪問診療とは</a
          >
        </li>
        <li>
          <a
            href="#features"
            class="inline-flex items-center rounded-full px-2.5 py-1 sm:px-3 font-medium text-gray-700 dark:text-gray-200 hover:bg-blue-50 dark:hover:bg-slate-800 hover:text-primary transition-colors"
            >選ばれる理由</a
          >
        </li>
        <li>
          <a
            href="#first-visit"
            class="inline-flex items-center rounded-full px-2.5 py-1 sm:px-3 font-medium text-gray-700 dark:text-gray-200 hover:bg-blue-50 dark:hover:bg-slate-800 hover:text-primary transition-colors"
            >流れ・費用・対象</a
          >
        </li>
        <li>
          <a
            href="#departments"
            class="inline-flex items-center rounded-full px-2.5 py-1 sm:px-3 font-medium text-gray-700 dark:text-gray-200 hover:bg-blue-50 dark:hover:bg-slate-800 hover:text-primary transition-colors"
            >診療内容</a
          >
        </li>
        <li>
          <a
            href="#faq"
            class="inline-flex items-center rounded-full px-2.5 py-1 sm:px-3 font-medium text-gray-700 dark:text-gray-200 hover:bg-blue-50 dark:hover:bg-slate-800 hover:text-primary transition-colors"
            >よくある質問</a
          >
        </li>
        <li>
          <a
            href="#contact"
            class="inline-flex items-center rounded-full px-2.5 py-1 sm:px-3 font-medium text-gray-700 dark:text-gray-200 hover:bg-blue-50 dark:hover:bg-slate-800 hover:text-primary transition-colors"
            >相談窓口</a
          >
        </li>
      </ul>
    </div>
  </nav>

  <!-- 訪問診療とは（要約 → 詳細は専用ページ） -->
  <section id="about-houmon" class="scroll-mt-32 py-6 md:py-10 bg-white dark:bg-slate-900">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-sm font-semibold text-primary tracking-widest mb-1">訪問診療について</p>
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white mb-4">訪問診療とは</h2>
      <div
        class="bg-blue-50 dark:bg-slate-800 rounded-2xl p-5 md:p-7 text-left space-y-3 text-gray-800 dark:text-gray-200 leading-relaxed"
      >
        <p>
          <strong>訪問診療</strong
          >とは、医師がご自宅や入居施設へ定期的に伺い、診察・処方・検査などを行う医療です。通院が難しい方が、住み慣れた場所で治療を続けられるようにするサービスで、<strong
            >健康保険・介護保険が適用</strong
          >されます。
        </p>
        <p class="text-sm text-gray-600 dark:text-gray-400">
          往診（急変時の臨時訪問）とは違います。当院は計画的な訪問診療に加え、<strong>24時間365日の緊急往診</strong
          >にも対応しています。
        </p>
      </div>
      <div class="mt-5 flex flex-wrap justify-center gap-3">
        <a
          href="/houmon-shinryo"
          class="inline-flex items-center gap-2 bg-primary text-white font-bold px-5 py-2.5 rounded-full text-sm hover:opacity-90"
        >
          <Icon name="tabler:arrow-right" class="w-4 h-4" /> くわしい説明・対象・流れを見る
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================ 実績数バナー ================================================================ -->
  <section class="py-10 bg-primary dark:bg-slate-800">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4 text-center text-white">
        <div>
          <p class="text-3xl md:text-4xl font-black mb-1">2017<span class="text-lg">年</span></p>
          <p class="text-sm font-semibold opacity-90">開院</p>
        </div>
        <div>
          <p class="text-3xl md:text-4xl font-black mb-1">
            {cumulativeStats.totalPatients ?? '1,000'}<span class="text-lg"
              >{cumulativeStats.totalPatients ? '' : '名'}</span
            >
          </p>
          <p class="text-sm font-semibold opacity-90">延べ患者数</p>
        </div>
        <div>
          <p class="text-3xl md:text-4xl font-black mb-1">
            {cumulativeStats.totalVisits ?? '1.2'}<span class="text-lg"
              >{cumulativeStats.totalVisits ? '' : '万件'}</span
            >
          </p>
          <p class="text-sm font-semibold opacity-90">年間診察件数</p>
        </div>
        <div>
          <p class="text-3xl md:text-4xl font-black mb-1">5<span class="text-lg">院</span></p>
          <p class="text-sm font-semibold opacity-90">大阪市内拠点</p>
        </div>
        <div class="col-span-2 sm:col-span-1">
          <p class="text-xl md:text-2xl font-black mb-1 leading-tight">厚労省<br />最上位認定</p>
          <p class="text-xs font-semibold opacity-90">24h体制の在宅医療</p>
        </div>
      </div>
      {/* Googleレビューバッジ（src/data/clinic-meta.ts に値が設定されたら自動表示） */}
      {
        googleReview.ratingValue !== null && googleReview.reviewCount !== null && (
          <div class="mt-6 flex justify-center">
            <div class="inline-flex items-center gap-3 bg-white/15 rounded-2xl px-6 py-3">
              <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor" class="text-white">
                <path
                  d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
                  fill="#4285F4"
                />
                <path
