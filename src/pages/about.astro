---

<Layout metadata={metadata}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdBreadcrumb)} />
  </Fragment>

  <!-- ===== Hero ===== -->
  <Hero
    tagline="クリニック紹介"
    image={{
      src: 'https://www.kamome-clinic.net/images/top/slider02.jpg',
      alt: 'かもめクリニックのスタッフチーム',
    }}
  >
    <Fragment slot="title">
      大阪市の在宅医療を<br />
      <span class="text-accent dark:text-white highlight">チームで支える</span><br />
      クリニック
    </Fragment>
    <Fragment slot="subtitle">
      2017年開院。内科・精神科・小児科の専門医が連携し、<br class="hidden sm:inline" />
      大阪市内5院体制で<strong>24時間365日の在宅医療</strong>を提供しています。<br class="hidden sm:inline" />
      厚生労働省が定める最上位認定（在支診1）を取得し、地域に根ざした訪問診療を支え続けています。
    </Fragment>
  </Hero>

  <!-- ===== 実績数値 ===== -->
  <Stats
    title="かもめクリニックの実績"
    stats={[
      { title: '開院', amount: '2017年' },
      { title: '常勤医師', amount: '13名' },
      { title: '市内拠点', amount: '5院' },
      { title: '年間看取り', amount: '約100件' },
    ]}
  />

  <!-- ===== ミッション ===== -->
  <section class="py-16 bg-white dark:bg-slate-900">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-10">
        <p class="text-sm font-semibold text-primary tracking-widest mb-1">私たちの理念</p>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white">クリニックの理念</h2>
      </div>
      <div class="bg-blue-50 dark:bg-slate-800 rounded-2xl p-8 md:p-10 mb-8 border border-blue-100 dark:border-slate-700">
        <p class="text-xl md:text-2xl font-bold text-gray-900 dark:text-white leading-relaxed text-center mb-4">
          「住み慣れた場所で、<br class="hidden sm:inline" />最期まで自分らしく生きる」<br class="hidden sm:inline" />を支える医療
        </p>
        <p class="text-gray-600 dark:text-gray-400 leading-relaxed text-center">
          通院が困難な患者さまとご家族が、<br class="hidden sm:inline" />
          住み慣れた自宅や施設で安心して医療を受け続けられるよう、<br class="hidden sm:inline" />
          大阪市内の在宅医療を支え続けています。
        </p>
      </div>

      <div class="grid sm:grid-cols-3 gap-5">
        {[
          {
            icon: 'tabler:clock-24',
            title: '24時間365日の安心',
            body: '厚生労働省が定める在宅医療最高水準クリニックとして、夜間・休日も緊急往診に対応。「いざというとき」の不安を取り除きます。',
          },
          {
            icon: 'tabler:users',
            title: '内科・精神科・小児科の連携',
            body: '複合的な疾患を持つ患者さまも、1つのクリニックで一体的に対応できます。専門医チームが連携して診療にあたります。',
          },
          {
            icon: 'tabler:map-pin',
            title: '大阪市内5拠点の広域対応',
            body: '港区・西淀川区・住之江区ほか市内広域に5院体制。担当エリアのご確認は地域医療連携部が一括対応します。',
          },
        ].map(({ icon, title, body }) => (
          <div class="bg-white dark:bg-slate-800 rounded-xl border border-gray-100 dark:border-slate-700 p-6 flex flex-col gap-3">
            <Icon name={icon} class="w-8 h-8 text-primary" />
            <p class="font-bold text-gray-900 dark:text-white">{title}</p>
            <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== 医師紹介 ===== -->
  <section id="doctors" class="py-16 bg-blue-50 dark:bg-slate-800">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-10">
        <p class="text-sm font-semibold text-primary tracking-widest mb-1">医師紹介</p>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white">医師紹介</h2>
        <p class="text-gray-500 dark:text-gray-400 mt-3">
          常勤医師13名。内科・精神科・小児科の専門医が連携して診療にあたります。ほか、非常勤医師（内科4名・泌尿器科1名・精神科5名）が参加しています。
        </p>
      </div>

      {/* ───── タブ切替 ───── */}
      <div class="flex gap-2 mb-6 overflow-x-auto pb-1" id="doctor-tabs" role="tablist">
        {[
          { id: '内科',   label: '内科（9名）',   color: 'bg-blue-600'   },
          { id: '精神科', label: '精神科（3名）', color: 'bg-purple-600' },
          { id: '小児科', label: '小児科（1名）', color: 'bg-green-600'  },
        ].map(({ id, label, color }, i) => (
          <button
            type="button"
            role="tab"
            data-tab={id}
            aria-selected={i === 0 ? 'true' : 'false'}
            class={`doctor-tab shrink-0 font-bold px-5 py-2.5 rounded-full text-sm transition-colors border-2 ${
              i === 0
                ? `${color} text-white border-transparent`
                : 'bg-white dark:bg-slate-900 text-gray-600 dark:text-gray-300 border-gray-200 dark:border-slate-600'
            }`}
          >
            {label}
          </button>
        ))}
      </div>

      {/* ───── タブパネル ───── */}
      {[
        { dept: '内科',   panelColor: 'blue'   },
        { dept: '精神科', panelColor: 'purple' },
        { dept: '小児科', panelColor: 'green'  },
      ].map(({ dept, panelColor }, i) => (
        <div
          id={`panel-${dept}`}
          role="tabpanel"
          class={`doctor-panel ${i !== 0 ? 'hidden' : ''}`}
        >
          <div class="grid sm:grid-cols-2 gap-5">
            {doctors.filter(d => d.dept === dept).map(({ name, role, dept: d, color, badgeColor, certs, icon, image, message, href }) => (
              <div class={`rounded-2xl border p-6 flex flex-col gap-4 ${color}`}>
                <div class="flex items-start gap-4">
                  {image ? (
                    <img
                      src={image}
                      alt={`${name}の写真`}
                      class="w-24 h-28 rounded-xl object-cover object-top shrink-0 shadow-md border-2 border-white dark:border-slate-600"
                    />
                  ) : (
                    <div class="w-24 h-28 rounded-xl shrink-0 bg-gray-100 dark:bg-slate-700 flex flex-col items-center justify-center border-2 border-gray-200 dark:border-slate-500 text-center">
                      <Icon name="tabler:user" class="w-8 h-8 text-gray-400 dark:text-gray-500" />
                      <span class="text-sm text-gray-400 dark:text-gray-500 leading-tight mt-1">準備中</span>
                    </div>
                  )}
                  <div class="flex-1">
                    <div class="flex items-center gap-2 flex-wrap mb-1">
                      <h3 class="text-xl font-black text-gray-900 dark:text-white">{name}</h3>
                      <span class={`text-white text-xs font-bold px-2 py-0.5 rounded-full ${badgeColor}`}>{d}</span>
                    </div>
                    <p class="text-sm text-gray-500 dark:text-gray-400 font-medium">{role}</p>
                  </div>
                </div>
                <div class="flex flex-wrap gap-1.5">
                  {certs.map((c) => (
                    <span class="bg-white dark:bg-slate-700 border border-gray-200 dark:border-slate-600 text-sm text-gray-600 dark:text-gray-300 px-2.5 py-1 rounded-full">{c}</span>
                  ))}
                </div>
                <p class="text-sm text-gray-600 dark:text-gray-300 italic leading-relaxed border-l-4 border-primary/30 pl-3">
                  「{message}」
                </p>
                {href && (
                  <a href={href} class="mt-auto inline-flex items-center gap-1 text-primary text-sm font-bold hover:underline">
                    院長プロフィールを見る <Icon name="tabler:arrow-right" class="w-4 h-4" />
                  </a>
                )}
              </div>
            ))}
          </div>
        </div>
      ))}

      <div class="mt-12 rounded-2xl border border-blue-100 dark:border-slate-600 bg-white dark:bg-slate-900 p-6 md:p-8 shadow-sm">
        <h3 class="text-xl font-bold text-gray-900 dark:text-white text-center mb-2">非常勤医師</h3>
        <p class="text-sm text-gray-600 dark:text-gray-400 text-center mb-6">
          常勤医師に加え、科別に以下の非常勤医師が診療に参加しています。
        </p>
        <ul class="grid sm:grid-cols-3 gap-4 max-w-3xl mx-auto">
          <li class="rounded-xl bg-blue-50 dark:bg-slate-800 border border-blue-100 dark:border-slate-600 py-5 px-4 text-center">
            <p class="text-sm font-semibold text-gray-600 dark:text-gray-400">内科</p>
            <p class="text-2xl font-black text-blue-600 dark:text-blue-400 mt-1">4名</p>
          </li>
          <li class="rounded-xl bg-amber-50 dark:bg-slate-800 border border-amber-100 dark:border-amber-900/30 py-5 px-4 text-center">
            <p class="text-sm font-semibold text-gray-600 dark:text-gray-400">泌尿器科</p>
            <p class="text-2xl font-black text-amber-700 dark:text-amber-400 mt-1">1名</p>
          </li>
          <li class="rounded-xl bg-purple-50 dark:bg-slate-800 border border-purple-100 dark:border-purple-900/30 py-5 px-4 text-center">
            <p class="text-sm font-semibold text-gray-600 dark:text-gray-400">精神科</p>
            <p class="text-2xl font-black text-purple-600 dark:text-purple-400 mt-1">5名</p>
          </li>
        </ul>
      </div>

      <p class="text-center text-sm text-gray-500 dark:text-gray-400 mt-6">
        ※上記の医師紹介は常勤医師です。看護師・事務スタッフも在籍しています。
      </p>
    </div>
  </section>

  <script>
    function initDoctorTabs() {
      const tabs   = document.querySelectorAll<HTMLButtonElement>('.doctor-tab');
      const panels = document.querySelectorAll<HTMLElement>('.doctor-panel');
      const tabColors: Record<string, string> = {
        '内科':   'bg-blue-600',
        '精神科': 'bg-purple-600',
        '小児科': 'bg-green-600',
      };
      tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          const target = tab.dataset.tab;
          tabs.forEach((t) => {
            const dept = t.dataset.tab ?? '';
            const active = t === tab;
            t.setAttribute('aria-selected', String(active));
            t.className = t.className
              .replace(/bg-\w+-600|text-white|border-transparent|bg-white dark:bg-slate-900 text-gray-600 dark:text-gray-300 border-gray-200 dark:border-slate-600/g, '').trim();
            if (active) {
              t.classList.add(tabColors[dept] ?? 'bg-primary', 'text-white', 'border-transparent');
              t.classList.remove('bg-white', 'dark:bg-slate-900', 'text-gray-600', 'dark:text-gray-300', 'border-gray-200', 'dark:border-slate-600');
            } else {
              t.classList.add('bg-white', 'dark:bg-slate-900', 'text-gray-600', 'dark:text-gray-300', 'border-gray-200', 'dark:border-slate-600');
              t.classList.remove(tabColors[dept] ?? 'bg-primary', 'text-white', 'border-transparent');
            }
          });
          panels.forEach((p) => {
            p.id === `panel-${target}` ? p.classList.remove('hidden') : p.classList.add('hidden');
          });
        });
      });
    }
    document.addEventListener('astro:page-load', initDoctorTabs);
    initDoctorTabs();
  </script>

