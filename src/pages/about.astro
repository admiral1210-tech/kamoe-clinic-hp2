---
import Stats from '~/components/widgets/Stats.astro';
import Hero from '~/components/widgets/Hero.astro';
import BranchLocations from '~/components/widgets/BranchLocations.astro';
import Layout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';
import { KAMOME_BRANCH_COUNT } from '~/data/branches';
import { OSAKA_CITY_WARDS } from '~/data/osaka-wards';
import {
  clinicalHeroSubtitleClass,
  clinicalHeroTaglineClass,
  clinicalHeroTitleClass,
} from '~/constants/clinical-page-ui';
import { serializeJsonLdForScript } from '~/utils/json-ld-script';
const branchCount = KAMOME_BRANCH_COUNT;

const metadata = {
  title: 'クリニック紹介｜かもめクリニック（大阪市）',
  description: `かもめクリニックの紹介ページ。2017年開院、大阪市内${branchCount}院・在支診1認定。内科・精神科・小児科の専門医が連携して在宅医療を提供します。`,
  ignoreTitleTemplate: true,
};

// JSON-LD: BreadcrumbList
const jsonLdBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'トップページ', item: 'https://kamome-clinic.net/' },
    { '@type': 'ListItem', position: 2, name: 'クリニック紹介', item: 'https://kamome-clinic.net/about' },
  ],
};
---

<Layout metadata={metadata}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={serializeJsonLdForScript(jsonLdBreadcrumb)} />
  </Fragment>

  <!-- ===== Hero ===== -->
  <Hero
    tagline="クリニック紹介"
    taglineClass={clinicalHeroTaglineClass}
    titleClass={clinicalHeroTitleClass}
    subtitleClass={clinicalHeroSubtitleClass}
  >
    <Fragment slot="title">
      大阪市の在宅医療を<br />
      <span class="text-accent dark:text-white highlight">チームで支える</span><br />
      クリニック
    </Fragment>
    <Fragment slot="subtitle">
      2017年開院。内科・精神科・小児科の専門医が連携し、<br class="hidden sm:inline" />
      大阪市内{branchCount}院体制で<strong>24時間365日の在宅医療</strong>を提供しています。<br class="hidden sm:inline" />
      厚生労働省の施設基準（在支診1・機能強化型）を届出し、地域に根ざした訪問診療を続けています。
    </Fragment>
  </Hero>

  <!-- ===== 実績数値 ===== -->
  <Stats
    title="かもめクリニックの実績"
    stats={[
      { title: '開院', amount: '2017年' },
      { title: '常勤医師', amount: '13名' },
      { title: '市内拠点', amount: `${branchCount}院` },
      { title: '年間看取り', amount: '約100件' },
    ]}
    footnote="※常勤医師数・拠点数は2025年12月時点。年間看取りは2025年1月〜12月の実績値です。"
  />

  <!-- ===== ミッション ===== -->
  <section class="py-16 bg-white dark:bg-slate-900">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-10">
        <p class="text-sm font-semibold text-primary tracking-widest mb-1">私たちの理念</p>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white">クリニックの理念</h2>
      </div>
      <div
        class="bg-blue-50 dark:bg-slate-800 rounded-2xl p-8 md:p-10 mb-8 border border-blue-100 dark:border-slate-700"
      >
        <p class="text-xl md:text-2xl font-bold text-gray-900 dark:text-white leading-relaxed text-center mb-4">
          「住み慣れた場所で、<br class="hidden sm:inline" />最期まで自分らしく生きる」<br
            class="hidden sm:inline"
          />を支える医療
        </p>
        <p class="text-gray-600 dark:text-gray-400 leading-relaxed text-center">
          通院が困難な患者さまとご家族が、<br class="hidden sm:inline" />
          住み慣れた自宅や施設で安心して医療を受け続けられるよう、<br class="hidden sm:inline" />
          大阪市内の在宅医療を支え続けています。
        </p>
      </div>
    </div>
  </section>

  <!-- ===== 診療時間（トップからの深いリンク用） ===== -->
  <section
    id="hours"
    class="py-16 bg-[#f7f3ec] dark:bg-slate-900 bg-[radial-gradient(circle_at_center,_rgba(100,80,60,0.07)_1px,_transparent_1px)] dark:bg-none bg-[length:18px_18px]"
  >
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-10">
        <p class="text-sm font-semibold text-primary tracking-widest mb-1">診療時間・休診日</p>
        <h2 class="text-3xl md:text-4xl font-bold text-stone-800 dark:text-white">診療時間</h2>
        <p class="mt-4 text-sm text-stone-600 dark:text-gray-300 max-w-2xl mx-auto leading-relaxed">
          平日は午前・午後の2枠で診療しています。土曜・日曜・祝日は休診です。
        </p>
      </div>
      <div class="rounded-xl border border-stone-200/80 dark:border-slate-700 bg-white/70 dark:bg-slate-800/80 backdrop-blur-sm shadow-sm overflow-hidden">
        <table class="w-full table-fixed border-collapse text-center text-stone-700 dark:text-gray-200">
          <thead>
            <tr class="border-b border-stone-300 dark:border-slate-600">
              <th
                scope="col"
                class="w-[26%] sm:w-[14rem] py-3 pl-3 pr-1 sm:py-4 sm:pl-5 sm:pr-3 text-left text-xs sm:text-base font-bold text-stone-800 dark:text-white align-bottom"
              >
                診療時間
              </th>
              {
                ['月', '火', '水', '木', '金', '土'].map((d) => (
                  <th
                    scope="col"
                    class="py-3 px-0.5 sm:py-4 sm:px-2 text-[0.7rem] sm:text-sm font-semibold text-stone-800 dark:text-white align-bottom"
                  >
                    {d}
                  </th>
                ))
              }
              <th
                scope="col"
                class="py-3 px-0.5 sm:py-4 sm:px-2 text-[0.7rem] sm:text-sm font-semibold text-stone-800 dark:text-white align-bottom"
              >
                <abbr title="日曜・祝日" class="sm:hidden no-underline">日祝</abbr>
                <span class="hidden sm:inline">日・祝</span>
              </th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-stone-200 dark:border-slate-600">
              <th
                scope="row"
                class="py-3 pl-3 pr-1 sm:py-4 sm:pl-5 sm:pr-3 text-left text-xs sm:text-base font-medium text-stone-800 dark:text-gray-100"
              >
                9:00-12:00
              </th>
              {
                [1, 2, 3, 4, 5].map(() => (
                  <td class="py-3 px-0.5 sm:py-4 sm:px-2">
                    <span
                      class="text-[#a07840] dark:text-amber-500/90 text-base sm:text-xl leading-none"
                      aria-label="診療あり">●</span>
                  </td>
                ))
              }
              <td class="py-3 px-0.5 sm:py-4 sm:px-2 text-stone-600 dark:text-gray-400 text-xs sm:text-base font-medium">
                休
              </td>
              <td class="py-3 px-0.5 sm:py-4 sm:px-2 text-stone-600 dark:text-gray-400 text-xs sm:text-base font-medium">
                休
              </td>
            </tr>
            <tr class="border-b border-stone-300 dark:border-slate-600">
              <th
                scope="row"
                class="py-3 pl-3 pr-1 sm:py-4 sm:pl-5 sm:pr-3 text-left text-xs sm:text-base font-medium text-stone-800 dark:text-gray-100"
              >
                13:00-17:00
              </th>
              {
                [1, 2, 3, 4, 5].map(() => (
                  <td class="py-3 px-0.5 sm:py-4 sm:px-2">
                    <span
                      class="text-[#a07840] dark:text-amber-500/90 text-base sm:text-xl leading-none"
                      aria-label="診療あり">●</span>
                  </td>
                ))
              }
              <td class="py-3 px-0.5 sm:py-4 sm:px-2 text-stone-600 dark:text-gray-400 text-xs sm:text-base font-medium">
                休
              </td>
              <td class="py-3 px-0.5 sm:py-4 sm:px-2 text-stone-600 dark:text-gray-400 text-xs sm:text-base font-medium">
                休
              </td>
            </tr>
          </tbody>
        </table>
      </div>
      <div class="mt-8 space-y-1 text-sm text-stone-600 dark:text-gray-400 text-center sm:text-left max-w-2xl mx-auto sm:mx-0">
        <p>休診：土曜・日曜・祝日</p>
        <p>※緊急の場合は24時間、365日対応</p>
      </div>
    </div>
  </section>

  <BranchLocations />

  <!-- ===== 対応エリア ===== -->
  <section class="py-10 bg-white dark:bg-slate-900 border-t border-gray-100 dark:border-slate-800">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-sm font-semibold text-primary tracking-widest mb-3">対応エリア</p>
      <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">大阪市24区（訪問診療・緊急往診）</h3>
      <p class="text-sm text-gray-600 dark:text-gray-400 mb-5 max-w-2xl mx-auto leading-relaxed">
        対象エリアは大阪市全域です。紹介ページのある区はリンクからご覧ください。
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-2">
        {
          OSAKA_CITY_WARDS.map(({ name, slug }) =>
            slug ? (
              <a
                href={`/area/${slug}`}
                class="bg-blue-50 dark:bg-slate-800 hover:bg-blue-100 dark:hover:bg-slate-700 border border-blue-100 dark:border-slate-700 text-primary font-bold px-3 py-2.5 rounded-full text-sm transition-colors inline-flex items-center justify-center gap-1"
              >
                大阪市{name}
                <Icon name="tabler:arrow-right" class="w-3.5 h-3.5 shrink-0" />
              </a>
            ) : (
              <span class="bg-slate-50 dark:bg-slate-800/80 border border-dashed border-blue-100 dark:border-slate-600 text-gray-700 dark:text-gray-300 px-3 py-2.5 rounded-full text-sm inline-flex flex-col sm:flex-row items-center justify-center gap-0.5 leading-tight">
                <span>大阪市{name}</span>
                <span class="text-xs text-gray-500 dark:text-gray-500">（詳細はお電話）</span>
              </span>
            )
          )
        }
      </div>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-4">
        大阪市外のご相談も、地域医療連携部（06-4301-7883）へお問い合わせください。
      </p>
    </div>
  </section>
</Layout>
