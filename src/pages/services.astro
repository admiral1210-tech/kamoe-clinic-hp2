---
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Layout from '~/layouts/PageLayout.astro';
import {
  clinicalHeroSubtitleClass,
  clinicalHeroTaglineClass,
  clinicalHeroTitleClass,
  clinicalSectionHeadline,
} from '~/constants/clinical-page-ui';
const metadata = {
  title: '診療内容｜内科・精神科・小児科・ターミナルケア｜かもめクリニック',
  description:
    'かもめクリニックの診療内容。内科・精神科・小児科の訪問診療、ターミナルケア、24時間365日の緊急往診に対応。精神科専門医3名常勤・精神保健指定医在籍。',
  robots: { index: false, follow: false },
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="診療内容"
    taglineClass={clinicalHeroTaglineClass}
    titleClass={clinicalHeroTitleClass}
    subtitleClass={clinicalHeroSubtitleClass}
  >
    <Fragment slot="title">内科・精神科・小児科の<br />訪問診療に対応</Fragment>
    <Fragment slot="subtitle">
      ご自宅・施設へ医師が定期的に伺い、診察・処方・各種検査を行う<strong>訪問診療専門クリニック</strong>です。内科・精神科・小児科に対応し、<strong
        >24時間365日の緊急往診</strong
      >で在宅生活をしっかり支えます。
    </Fragment>
  </Hero>

  <Features2
    tagline="診療の特徴"
    title="主な診療内容"
    subtitle="通院が困難な方のご自宅・施設へ、専門の医師が定期的に伺います。"
    classes={{ headline: { ...clinicalSectionHeadline }, container: 'max-w-7xl mx-auto' }}
    columns={3}
    items={[
      {
        title: '内科（一般訪問診療）',
        description:
          '高血圧・糖尿病・心不全・COPD・慢性腎臓病などの生活習慣病や慢性疾患の管理。点滴・褥瘡処置・カテーテル管理なども対応します。',
        icon: 'tabler:stethoscope',
      },
      {
        title: '精神科（専門医3名常勤）',
        description:
          '精神科専門医3名が常勤し、精神保健指定医も在籍しています。うつ病・統合失調症・認知症・依存症・発達障がいなど、幅広い精神科疾患に対応します。',
        icon: 'tabler:brain',
      },
      {
        title: '小児科（医療的ケア児）',
        description:
          '医療的ケアが必要なお子さまや、障がいのある子どもの訪問診療に対応。学校・保育所・自宅など生活の場へ伺います。',
        icon: 'tabler:baby-carriage',
      },
      {
        title: 'ターミナルケア（在宅看取り）',
        description:
          'グループ全体で年間約100件の在宅看取りを実施。ご本人の想いを最優先に、ご家族への丁寧なサポートと多職種連携で最期まで支えます。',
        icon: 'tabler:heart-handshake',
      },
      {
        title: '緊急往診（24時間365日）',
        description:
          '機能強化型在宅療養支援診療所（在支診1）として、夜間・休日・年末年始を問わず急変時に対応できる体制を整えています。地域のかかりつけ医として継続的に寄り添います。',
        icon: 'tabler:ambulance',
      },
      {
        title: '施設・グループホーム対応',
        description:
          '対応施設50以上。有料老人ホーム・グループホーム・サービス付き高齢者向け住宅など、各種施設への定期訪問に対応しています。',
        icon: 'tabler:building-community',
      },
    ]}
  />

  <Content
    isReversed
    classes={{
      headline: {
        ...clinicalSectionHeadline,
        container: 'max-w-3xl mx-auto text-left sm:text-center',
      },
    }}
    items={[
      {
        title: '精神科専門医3名常勤',
        description: '精神科専門医が3名常勤し、精神保健指定医も在籍しています。',
        icon: 'tabler:certificate',
      },
      {
        title: 'うつ病・統合失調症・認知症・依存症',
        description: '精神科疾患を持つ方の在宅療養を、専門医が継続的にサポートします。',
        icon: 'tabler:brain',
      },
      {
        title: '薬剤調整・訪問看護との連携',
        description: '向精神薬の管理・調整から、訪問看護・ヘルパーとの多職種連携まで対応します。',
        icon: 'tabler:pill',
      },
      {
        title: '措置入院・精神科救急にも対応',
        description: '緊急時には精神科救急や入院調整のサポートも行います。',
        icon: 'tabler:urgent',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1559757175-0eb30cd8c063?auto=format&fit=crop&w=870&q=80',
      alt: '精神科訪問診療',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">精神科の訪問診療</h3>
      <p class="text-muted">精神科専門医3名が常勤し、精神保健指定医も在籍。精神疾患を抱える方の在宅療養を支えます。</p>
    </Fragment>
  </Content>

  <Content
    isAfterContent
    classes={{
      headline: {
        ...clinicalSectionHeadline,
        container: 'max-w-3xl mx-auto text-left sm:text-center',
      },
    }}
    items={[
      {
        title: 'ご本人の想いを最優先に',
        description: '「自宅で最期を迎えたい」「住み慣れた場所にいたい」というご本人・ご家族の意向を丁寧に確認しながら進めます。',
        icon: 'tabler:heart',
      },
      {
        title: '年間約100件の在宅看取り実績',
        description: 'グループ全体で年間約100件の在宅看取りを実施。多職種連携の体制で最期の時間を継続的に支えます。',
        icon: 'tabler:home-heart',
      },
      {
        title: 'ご家族へのサポート',
        description: '看取り後のグリーフケアも含め、ご家族が安心して送り出せるよう丁寧に寄り添います。',
        icon: 'tabler:users',
      },
      {
        title: '多職種・関係機関との連携',
        description: '訪問看護・ケアマネージャー・MSW・薬剤師など、関係各所と密に連携しながら支援します。',
        icon: 'tabler:network',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1582750433449-648ed127bb54?auto=format&fit=crop&w=774&q=80',
      alt: 'ターミナルケア・在宅看取り',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">ターミナルケア・在宅看取り</h3>
      <p class="text-muted">
        グループ全体で年間約100件の在宅看取りを実施。ご本人・ご家族への丁寧なケアと、関係各所との連携を大切にしています。
      </p>
    </Fragment>
  </Content>
</Layout>
