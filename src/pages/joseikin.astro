---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import PageTocNav from '~/components/ui/PageTocNav.astro';
import PageSectionHeading from '~/components/ui/PageSectionHeading.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import ClinicalPageClosing from '~/components/widgets/ClinicalPageClosing.astro';
import { Icon } from 'astro-icon/components';
import {
  clinicalAnchorScrollMargin,
  clinicalHeroSubtitleClass,
  clinicalHeroTaglineClass,
  clinicalHeroTitleClass,
  clinicalSectionHeadline,
} from '~/constants/clinical-page-ui';
import { CLINIC_CONTACT } from '~/data/clinic-contact';
import {
  joseikinFlowSteps,
  joseikinJoseiFeatureItems,
  joseikinPointItems,
  joseikinShindanshoFeatureItems,
} from '~/data/joseikin-content';
import { joseikinFaqEntries } from '~/data/faq-joseikin';
import { getCanonical, getPermalink } from '~/utils/permalinks';
import { buildFaqPageJsonLd, faqEntriesToWidgetItems } from '~/utils/seo-faq';
import { serializeJsonLdForScript } from '~/utils/json-ld-script';

const siteHome = String(getCanonical('/'));
const pageCanonical = String(getCanonical('/joseikin'));
const ogImageUrl = String(getCanonical('/images/top/slider02.jpg'));

const metadata = {
  title: '医療費助成・診断書のご案内｜かもめクリニック（大阪市）',
  description:
    'かもめクリニックでは自立支援医療（精神通院）・身体障害者手帳・障害年金・難病医療など各種診断書の発行に対応。乳幼児医療費助成・高額療養費・公害・原爆など医療費助成制度の案内も行っています。',
  ignoreTitleTemplate: true,
  openGraph: {
    type: 'website',
    images: [{ url: ogImageUrl, width: 1400, height: 500 }],
  },
};

const jsonLdBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'トップページ', item: siteHome },
    { '@type': 'ListItem', position: 2, name: '医療費助成・診断書', item: pageCanonical },
  ],
};

const jsonLdFAQ = buildFaqPageJsonLd(joseikinFaqEntries);
const joseikinFaqWidgetItems = faqEntriesToWidgetItems(joseikinFaqEntries);

const heroActions = [
  { variant: 'primary' as const, href: CLINIC_CONTACT.telHref, text: '電話する', icon: 'tabler:phone' },
  {
    variant: 'secondary' as const,
    href: getPermalink('/renkei'),
    text: '問い合わせ',
    icon: 'tabler:clipboard-list',
  },
];

const siteFaqHref = getPermalink('/faq');
const contactFormHref = getPermalink('/renkei');
---

<Layout metadata={metadata}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={serializeJsonLdForScript(jsonLdBreadcrumb)} />
    <script type="application/ld+json" set:html={serializeJsonLdForScript(jsonLdFAQ)} />
  </Fragment>

  <!-- 1. ヒーローCTA（電話・問い合わせ） -->
  <Hero
    tagline="医療費助成・診断書｜大阪市の訪問診療"
    taglineClass={clinicalHeroTaglineClass}
    titleClass={clinicalHeroTitleClass}
    subtitleClass={clinicalHeroSubtitleClass}
    actions={heroActions}
  >
    <Fragment slot="title">
      医療費助成・<br />
      <span class="text-primary dark:text-blue-300">診断書</span>のご案内
    </Fragment>
    <Fragment slot="subtitle">
      かもめクリニックでは<strong>診断書の作成・発行</strong>に幅広く対応しています。<br class="hidden sm:inline" />
      医療費助成制度をうまく活用し、継続的な医療を無理なく受けていただけるようサポートします。
    </Fragment>
  </Hero>

  <PageTocNav
    ariaLabel="このページの主な内容"
    items={[
      { href: '#first-visit', label: 'はじめての方へ' },
      { href: '#shindansho', label: '診断書の種類' },
      { href: '#nagare', label: '発行の流れ' },
      { href: '#josei', label: '助成制度' },
      { href: '#points', label: '利用のポイント' },
      { href: '#faq', label: 'よくある質問' },
    ]}
  />

  <!-- 7. はじめての方へ（整形外科ページと同型） -->
  <section
    id="first-visit"
    class="scroll-mt-20 py-10 bg-gray-50 dark:bg-slate-800/50 border-y border-gray-100 dark:border-slate-700 not-prose"
  >
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <h2 class="text-xl md:text-2xl font-bold text-gray-900 dark:text-gray-100 text-center mb-3">
        はじめての方へ（ご家族の方も）
      </h2>
      <p class="text-sm md:text-base text-gray-600 dark:text-gray-300 text-center leading-relaxed mb-6">
        診断書の種類や申請先は制度ごとに異なります。まずはお電話またはフォームで、必要な書類と大まかな流れをご案内します。
      </p>
      <ol class="list-decimal pl-5 space-y-2 text-sm md:text-base text-gray-800 dark:text-gray-200 mb-6">
        <li>
          お電話（<a href={CLINIC_CONTACT.telHref} class="text-primary font-semibold underline"
            >{CLINIC_CONTACT.telDisplay}</a
          >）または<a href={contactFormHref} class="text-primary font-semibold underline">お問い合わせフォーム</a
          >で、必要な診断書または利用を検討している助成制度、申請の目安時期をお知らせください（{CLINIC_CONTACT.hoursPrimary}）。
        </li>
        <li>当院での対応可否・お持ちいただく書類の目安をご案内します。</li>
        <li>診察・書類作成の日程を調整し、完成後の受け取り方法をご説明します。</li>
      </ol>
      <p class="text-xs text-gray-500 dark:text-gray-400 text-center leading-relaxed">
        文書料・紹介状の要否などは個別に説明します。詳しくは<a href={siteFaqHref} class="text-primary underline"
          >よくある質問（サイト全体）</a
        >もご覧ください。
      </p>
    </div>
  </section>

  <!-- 5. 診断書の種類（要約＋続きを読む） -->
  <Features
    id="shindansho"
    scrollMarginClass={clinicalAnchorScrollMargin}
    tagline="診断書"
    title="発行できる診断書の種類"
    subtitle="訪問診療の中で必要な書類作成も一括対応します。申請期限がある場合はお早めにご相談ください。"
    classes={{ headline: { ...clinicalSectionHeadline } }}
    items={joseikinShindanshoFeatureItems}
  />

  <!-- 2・3. 発行の流れ（データ単一ソース・手順見出しは h3） -->
  <section
    id="nagare"
    class="scroll-mt-32 py-14 bg-blue-50 dark:bg-slate-800 border-y border-blue-100 dark:border-slate-700"
  >
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <PageSectionHeading
        tagline="流れ"
        title="診断書発行の流れ"
        subtitle="申請期限がある場合は余裕をもってご依頼ください"
      />
      <ol class="list-none pl-0 m-0 space-y-4">
        {
          joseikinFlowSteps.map(({ step, title, body }) => (
            <li class="flex gap-4 bg-white dark:bg-slate-900 rounded-xl border border-gray-100 dark:border-slate-700 px-5 py-4">
              <span class="bg-primary text-white font-black text-sm w-8 h-8 rounded-lg flex items-center justify-center shrink-0 mt-0.5">
                {step}
              </span>
              <div>
                <h3 class="font-bold text-gray-900 dark:text-white mb-1 text-base leading-snug">{title}</h3>
                <p class="text-sm text-gray-600 dark:text-gray-400">{body}</p>
              </div>
            </li>
          ))
        }
      </ol>
      <p class="text-center mt-6 text-sm text-gray-500 dark:text-gray-400">
        ※ 診断書の文書料は別途費用がかかります。金額はお問い合わせください。
      </p>
    </div>
  </section>

  <!-- 5. 助成制度（要約＋続きを読む） -->
  <Features2
    id="josei"
    scrollMarginClass={clinicalAnchorScrollMargin}
    tagline="助成制度"
    title="ご利用いただける医療費助成制度"
    subtitle="各制度の申請・手続きに関するご相談も承ります。まずはお気軽にお問い合わせください。"
    classes={{ headline: { ...clinicalSectionHeadline }, container: 'max-w-7xl mx-auto' }}
    columns={2}
    items={joseikinJoseiFeatureItems}
  />

  <!-- 4. 利用のポイント（意味的なリスト・見出しは h3） -->
  <section id="points" class="scroll-mt-32 py-14 bg-page dark:bg-slate-900">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <PageSectionHeading tagline="ポイント" title="制度を利用する際のポイント" />
      <ul class="list-none pl-0 m-0 space-y-4">
        {
          joseikinPointItems.map(({ icon, title, body }) => (
            <li class="flex gap-4 bg-white dark:bg-slate-900 rounded-xl border border-gray-100 dark:border-slate-700 px-5 py-4">
              <Icon name={icon} class="w-7 h-7 text-primary shrink-0 mt-0.5" aria-hidden="true" />
              <div>
                <h3 class="font-bold text-gray-900 dark:text-white mb-1 text-base leading-snug">{title}</h3>
                <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">{body}</p>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <FAQs
    id="faq"
    scrollMarginClass={clinicalAnchorScrollMargin}
    title="医療費助成・診断書に関するよくある質問"
    tagline="FAQ"
    classes={{ container: 'max-w-7xl', headline: { ...clinicalSectionHeadline } }}
    items={joseikinFaqWidgetItems}
  />

  <ClinicalPageClosing />
</Layout>
