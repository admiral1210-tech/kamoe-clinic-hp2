---

<Layout metadata={metadata}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdBreadcrumb)} />
  </Fragment>

  <!-- ===== Hero ===== -->
  <Hero
    tagline="クリニック紹介"
    image={{
      src: 'https://www.kamome-clinic.net/images/top/slider02.jpg',
      alt: 'かもめクリニックのスタッフチーム',
    }}
  >
    <Fragment slot="title">
      大阪市の在宅医療を<br />
      <span class="text-accent dark:text-white highlight">チームで支える</span><br />
      クリニック
    </Fragment>
    <Fragment slot="subtitle">
      2017年開院。内科・精神科・小児科の専門医が連携し、<br class="hidden sm:inline" />
      大阪市内5院体制で<strong>24時間365日の在宅医療</strong>を提供しています。<br class="hidden sm:inline" />
      厚生労働省が定める最上位認定（在支診1）を取得し、地域に根ざした訪問診療を支え続けています。
    </Fragment>
  </Hero>

  <!-- ===== 実績数値 ===== -->
  <Stats
    title="かもめクリニックの実績"
    stats={[
      { title: '開院', amount: '2017年' },
      { title: '常勤医師', amount: '13名' },
      { title: '市内拠点', amount: '5院' },
      { title: '年間看取り', amount: '約100件' },
    ]}
  />

  <!-- ===== ミッション ===== -->
  <section class="py-16 bg-white dark:bg-slate-900">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-10">
        <p class="text-sm font-semibold text-primary tracking-widest mb-1">私たちの理念</p>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white">クリニックの理念</h2>
      </div>
      <div
        class="bg-blue-50 dark:bg-slate-800 rounded-2xl p-8 md:p-10 mb-8 border border-blue-100 dark:border-slate-700"
      >
        <p class="text-xl md:text-2xl font-bold text-gray-900 dark:text-white leading-relaxed text-center mb-4">
          「住み慣れた場所で、<br class="hidden sm:inline" />最期まで自分らしく生きる」<br
            class="hidden sm:inline"
          />を支える医療
        </p>
        <p class="text-gray-600 dark:text-gray-400 leading-relaxed text-center">
          通院が困難な患者さまとご家族が、<br class="hidden sm:inline" />
          住み慣れた自宅や施設で安心して医療を受け続けられるよう、<br class="hidden sm:inline" />
          大阪市内の在宅医療を支え続けています。
        </p>
      </div>
    </div>
  </section>

  <!-- ===== ご利用対象（トップからの深いリンク用） ===== -->
  <section id="targets" class="py-16 bg-white dark:bg-slate-900 border-t border-gray-100 dark:border-slate-800">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-10">
        <p class="text-sm font-semibold text-primary tracking-widest mb-1">ご利用対象</p>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white">こんな方がご利用いただけます</h2>
        <p class="text-gray-500 dark:text-gray-400 mt-2 text-sm">
          上記以外でも、通院が困難であれば、どなたでもご利用いただけます。
        </p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {
          [
            {
              title: '通院困難な高齢者・障がいのある方',
              body: '足腰が弱く通院が難しくなった方、寝たきりや車いすの方にも対応します。',
              icon: 'tabler:wheelchair',
            },
            {
              title: '外出困難な精神疾患の方',
              body: 'うつ病・統合失調症・認知症など、精神科専門医がご自宅へ直接伺います。',
              icon: 'tabler:home-shield',
            },
            {
              title: '医療ケアが必要なお子さま',
              body: '人工呼吸器・経管栄養など、医療的ケアが必要なお子さまのご自宅へ小児科専門医が訪問します。',
              icon: 'tabler:baby-carriage',
            },
            {
              title: '退院後・施設入居中の方',
              body: '在宅療養中の方、老人ホーム・グループホームに入居中の方にも対応します。',
              icon: 'tabler:bed',
            },
          ].map(({ title, body, icon }) => (
            <div class="bg-blue-50 dark:bg-slate-800 rounded-xl border border-blue-100 dark:border-slate-700 p-5 flex gap-3">
              <Icon name={icon} class="w-8 h-8 text-primary shrink-0 mt-0.5" />
              <div>
                <p class="font-bold text-gray-900 dark:text-white mb-1">{title}</p>
                <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">{body}</p>
              </div>
            </div>
          ))
        }
      </div>
      <p class="text-center mt-8">
        <a
          href="/houmon-shinryo#targets"
          class="text-primary text-sm font-bold hover:underline inline-flex items-center gap-1"
        >
          訪問診療の説明・流れとあわせて見る <Icon name="tabler:arrow-right" class="w-4 h-4" />
        </a>
      </p>
    </div>
  </section>

  <!-- ===== 診療時間（トップからの深いリンク用） ===== -->
  <section id="hours" class="py-16 bg-blue-50 dark:bg-slate-800">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-10">
        <p class="text-sm font-semibold text-primary tracking-widest mb-1">診療時間・休診日</p>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white">診療時間</h2>
        <p class="mt-4 text-sm text-gray-600 dark:text-gray-300 max-w-2xl mx-auto leading-relaxed">
          受付は月曜から金曜の9:00〜17:00です。土曜・日曜・祝日は休診ですが、緊急往診は365日24時間対応しています。
        </p>
      </div>
      <div class="flex flex-col lg:flex-row gap-8 items-start">
        <div class="w-full lg:w-2/3">
          <div class="sm:hidden flex flex-col gap-3">
            <div
              class="bg-white dark:bg-slate-900 rounded-xl border border-gray-200 dark:border-slate-700 overflow-hidden"
            >
              <div class="bg-primary text-white font-bold px-4 py-2 text-sm">受付時間</div>
              <div class="divide-y divide-gray-100 dark:divide-slate-700">
                <div class="flex items-center justify-between px-4 py-3">
                  <span class="text-gray-700 dark:text-gray-300 font-medium">月〜金</span>
                  <span class="flex items-center gap-2">
                    <span class="text-sm text-gray-500">9:00〜17:00</span>
                    <span class="text-primary font-black text-xl">●</span>
                  </span>
                </div>
                <div class="flex items-center justify-between px-4 py-3">
                  <span class="text-gray-700 dark:text-gray-300 font-medium">土・日・祝</span>
                  <span class="text-gray-400 text-xl font-bold">✕</span>
                </div>
              </div>
            </div>
            <div
              class="bg-emerald-50 dark:bg-slate-900 rounded-xl border border-emerald-200 dark:border-slate-700 overflow-hidden"
            >
              <div class="bg-emerald-700 text-white font-bold px-4 py-2 text-sm">緊急往診</div>
              <div class="flex items-center justify-between px-4 py-3">
                <span class="text-gray-700 dark:text-gray-300 font-medium">毎日（365日）</span>
                <span class="flex items-center gap-2">
                  <span class="text-sm text-gray-500">24時間対応</span>
                  <span class="text-emerald-700 font-black text-xl">24h</span>
                </span>
              </div>
            </div>
          </div>
          <div class="hidden sm:block overflow-x-auto">
            <table class="w-full text-center border-collapse">
              <thead>
                <tr class="bg-primary text-white">
                  <th class="p-3 text-left rounded-tl-lg"></th>
                  {['月', '火', '水', '木', '金'].map((d) => <th class="p-4 text-lg">{d}</th>)}
                  <th class="p-4 opacity-60 text-lg">土</th>
                  <th class="p-4 opacity-60 text-lg rounded-tr-lg">日・祝</th>
                </tr>
              </thead>
              <tbody>
                <tr class="border-b border-gray-200 dark:border-gray-700">
                  <td class="p-4 text-left font-bold text-gray-700 dark:text-gray-300 bg-white dark:bg-slate-900">
                    受付時間<br /><span class="text-sm font-normal text-gray-500">9:00〜17:00</span>
                  </td>
                  {
                    ['●', '●', '●', '●', '●'].map((s) => (
                      <td class="p-4 text-primary font-black text-2xl bg-white dark:bg-slate-900">{s}</td>
                    ))
                  }
                  <td class="p-4 text-gray-400 bg-white dark:bg-slate-900 text-xl">✕</td>
                  <td class="p-4 text-gray-400 bg-white dark:bg-slate-900 text-xl">✕</td>
                </tr>
                <tr>
                  <td class="p-4 text-left font-bold text-gray-700 dark:text-gray-300 bg-white dark:bg-slate-900">
                    緊急往診<br /><span class="text-sm font-normal text-gray-500">24時間対応</span>
                  </td>
                  {
                    ['24h', '24h', '24h', '24h', '24h', '24h', '24h'].map((s) => (
                      <td class="p-4 font-black text-emerald-700 bg-emerald-50 dark:bg-slate-900">{s}</td>
                    ))
                  }
                </tr>
              </tbody>
            </table>
          </div>
        </div>
        <div class="w-full lg:w-1/3 flex flex-col gap-4">
          <div class="rounded-xl border border-gray-200 dark:border-gray-700 p-5 bg-white dark:bg-slate-900">
            <p class="font-bold text-gray-800 dark:text-white mb-1 text-lg">休診日</p>
            <p class="text-gray-700 dark:text-gray-300">
              土曜日・日曜日<br /><span class="text-sm text-gray-500">※緊急往診は365日24時間対応</span>
            </p>
          </div>
          <div class="rounded-xl border-2 border-primary p-5 bg-white dark:bg-slate-800">
            <p class="font-bold text-gray-800 dark:text-white mb-2 text-lg">お電話・LINE・フォーム</p>
            <a href="tel:0643017871" class="block text-3xl font-black text-primary mb-1 hover:underline">06-4301-7871</a
            >
            <a
              href="https://line.me/R/ti/p/%40512ysmzx"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 font-bold px-3 py-1.5 rounded-lg underline underline-offset-2 hover:opacity-80 transition-opacity"
              style="color:var(--aw-color-line); background-color: rgba(6,199,85,0.08);"
            >
              <Icon name="tabler:brand-line" class="w-5 h-5 shrink-0" /> LINE：@512ysmzx
            </a>
            <a
              href="https://docs.google.com/forms/d/e/1FAIpQLSdXxuP8iRtCW8fNrVf6zLnPI97tqk2StxX4n7Ix6HEwqSIJ_Q/viewform"
              target="_blank"
              rel="noopener noreferrer"
              class="text-primary hover:underline text-sm font-bold block mt-2">お問い合わせフォーム →</a
