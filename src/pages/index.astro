---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { Icon } from 'astro-icon/components';
import { buildAggregateRating, buildNumberOfEmployees, getBranchFoundingDate, cumulativeStats, googleReview } from '~/data/clinic-meta';

const metadata = {
  title: 'かもめクリニック｜大阪市の訪問診療 内科・精神科・小児科｜2017年開院',
  description:
    '大阪市の機能強化型在宅療養支援診療所（在支診1）。2017年開院9年の実績。グループ患者数1,000名・年間診察1.2万件。精神科専門医3名常勤（大阪市内唯一）。内科・精神科・小児科対応。24時間365日緊急往診。健康保険・介護保険適用。',
  ignoreTitleTemplate: true,
  openGraph: {
    type: 'website',
    images: [{ url: 'https://www.kamome-clinic.net/images/top/slider02.jpg', width: 1400, height: 500 }],
  },
  twitter: { cardType: 'summary_large_image' },
};

// ===== JSON-LD: 組織情報（機能強化型在支診1・LINE・foundingDate）=====
const jsonLdClinic = {
  '@context': 'https://schema.org',
  '@id': 'https://kamome-clinic.net/#clinic',
  '@type': ['MedicalClinic', 'LocalBusiness'],
  name: 'かもめクリニック',
