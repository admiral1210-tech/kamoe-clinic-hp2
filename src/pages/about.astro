  <script>
    function initDoctorTabs() {
      const tabs = document.querySelectorAll<HTMLButtonElement>('.doctor-tab');
      const panels = document.querySelectorAll<HTMLElement>('.doctor-panel');
      const tabColors: Record<string, string> = {
        内科: 'bg-blue-600',
        精神科: 'bg-purple-600',
        小児科: 'bg-green-600',
      };
      tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          const target = tab.dataset.tab;
          tabs.forEach((t) => {
            const dept = t.dataset.tab ?? '';
            const active = t === tab;
            t.setAttribute('aria-selected', String(active));
            t.className = t.className
              .replace(
                /bg-\w+-600|text-white|border-transparent|bg-white dark:bg-slate-900 text-gray-600 dark:text-gray-300 border-gray-200 dark:border-slate-600/g,
                ''
              )
              .trim();
            if (active) {
              t.classList.add(tabColors[dept] ?? 'bg-primary', 'text-white', 'border-transparent');
              t.classList.remove(
                'bg-white',
                'dark:bg-slate-900',
                'text-gray-600',
                'dark:text-gray-300',
                'border-gray-200',
                'dark:border-slate-600'
              );
            } else {
              t.classList.add(
                'bg-white',
                'dark:bg-slate-900',
                'text-gray-600',
                'dark:text-gray-300',
                'border-gray-200',
                'dark:border-slate-600'
              );
              t.classList.remove(tabColors[dept] ?? 'bg-primary', 'text-white', 'border-transparent');
            }
          });
          panels.forEach((p) => {
            if (p.id === `panel-${target}`) {
              p.classList.remove('hidden');
            } else {
              p.classList.add('hidden');
            }
          });
        });
      });
    }
    document.addEventListener('astro:page-load', initDoctorTabs);
    initDoctorTabs();
  </script>

