---
import { Icon } from 'astro-icon/components';
import { SITE } from 'astrowind:config';
import { getHomePermalink, getPermalink } from '~/utils/permalinks';
import { CLINIC_CONTACT } from '~/data/clinic-contact';
import FooterNavColumn from '~/components/widgets/FooterNavColumn.astro';
import type { FooterData } from '~/types/footer';

export interface Props extends FooterData {
  theme?: string;
}

const { socialLinks = [], secondaryLinks = [], links = [], theme = 'light' } = Astro.props;
---

<footer class:list={[{ dark: theme === 'dark' }, 'relative border-t border-gray-200 dark:border-slate-800 not-prose']}>
  <div class="dark:bg-dark absolute inset-0 pointer-events-none" aria-hidden="true"></div>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 dark:text-slate-300">
    <!-- 上段：クリニック情報 + リンクグリッド -->
    <div class="py-8 flex flex-col lg:flex-row gap-8 border-b border-gray-100 dark:border-slate-700">
      <!-- クリニック情報ブロック（住所・TEL・診療時間） -->
      <div class="shrink-0 space-y-4 lg:w-64">
        <a
          class="font-bold text-base text-gray-900 dark:text-white hover:text-primary transition-colors block"
          href={getHomePermalink()}
        >
          {SITE?.name}
        </a>

        <!-- 住所・診療時間 -->
        <address class="not-italic space-y-2 text-sm text-muted dark:text-gray-400">
          <p class="flex items-start gap-2">
            <Icon name="tabler:map-pin" class="w-4 h-4 shrink-0 mt-0.5 text-primary" aria-hidden="true" />
            <span>
              {CLINIC_CONTACT.postalCode}
              {' '}
              {CLINIC_CONTACT.addressLine1}
              <br />
              {CLINIC_CONTACT.addressLine2}
            </span>
          </p>
          <p class="flex items-start gap-2">
            <Icon name="tabler:clock" class="w-4 h-4 shrink-0 mt-0.5 text-primary" aria-hidden="true" />
            <span>
              <span class="text-gray-500 dark:text-gray-500 text-xs">通常受付：</span>{CLINIC_CONTACT.hoursPrimary}
              <br />
              {CLINIC_CONTACT.hoursEmergency}
            </span>
          </p>
        </address>

        <!-- 電話CTA カード -->
        <a
          href={CLINIC_CONTACT.telHref}
          class="flex items-center gap-3 rounded-xl bg-primary/10 hover:bg-primary/15 dark:bg-primary/20 dark:hover:bg-primary/30 px-4 py-3 transition-colors"
        >
          <Icon name="tabler:phone" class="w-5 h-5 shrink-0 text-primary" aria-hidden="true" />
          <span>
            <span class="block text-xs text-gray-500 dark:text-gray-400 mb-0.5">お電話でのご相談</span>
            <span class="font-bold text-lg text-primary tracking-wider leading-none"
              >{CLINIC_CONTACT.telDisplay}</span
            >
          </span>
        </a>

        <!-- お問い合わせリンク（電話の代替手段として直近に配置） -->
        <a
          href={getPermalink('/renkei')}
          class="flex items-center gap-1.5 text-sm text-primary hover:underline"
        >
          <Icon name="tabler:mail" class="w-4 h-4 shrink-0" aria-hidden="true" />
          メール・フォームでのお問い合わせ
        </a>

        <!-- Instagram QR（縮小・説明テキスト付き） -->
        {
          socialLinks.map(({ ariaLabel, href, icon, imageSrc, variant }) =>
            variant === 'instagram-qr' && imageSrc ? (
              <div class="flex items-center gap-3 pt-1">
                <a
                  href={href}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={ariaLabel}
                  class="shrink-0"
                >
                  <img
                    src={imageSrc}
                    alt="かもめクリニック Instagram QRコード"
                    width={240}
                    height={276}
                    class="h-14 w-auto object-contain rounded-lg bg-white border border-gray-200 dark:border-slate-700"
                    loading="lazy"
                    decoding="async"
                  />
                </a>
                <p class="text-xs text-gray-500 dark:text-gray-400 leading-snug">
                  Instagram<br />公式アカウント<br />
                  <span class="text-[#E4405F]">@kamomeclinic</span>
                </p>
              </div>
            ) : !variant && icon ? (
              <a
                href={href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={ariaLabel}
                class="inline-flex items-center justify-center rounded-xl p-2.5 text-muted dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
              >
                <Icon name={icon} class="w-6 h-6" />
              </a>
            ) : null
          )
        }
      </div>

      <!-- リンクグリッド（各セクション見出しあり） -->
      <h2 id="footer-nav-heading" class="sr-only">サイトマップ</h2>
      <nav
        class="grid grid-cols-1 lg:grid-cols-5 gap-x-4 gap-y-0 lg:gap-y-6 flex-1"
        aria-labelledby="footer-nav-heading"
      >
        {
          links.map(({ title, links: sectionLinks, collapsibleMobile }) => (
            <FooterNavColumn
              title={title}
              links={sectionLinks}
              collapsibleMobile={collapsibleMobile}
            />
          ))
        }
      </nav>
    </div>

    <!-- 下段：セカンダリリンク + コピーライト -->
    <div class="py-4 flex flex-wrap items-center justify-between gap-3 text-sm text-muted dark:text-muted">
      <div class="flex flex-wrap gap-4">
        {
          secondaryLinks.map(({ text, href }) => (
            <a
              class="hover:text-gray-700 dark:text-gray-400 hover:underline transition duration-150 ease-in-out"
              href={href}
            >
              {text}
            </a>
          ))
        }
      </div>
      <p class="text-xs text-muted dark:text-muted">
        © {new Date().getFullYear()} かもめクリニック
      </p>
    </div>
  </div>
</footer>
